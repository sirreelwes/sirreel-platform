enum UserRole {
  ADMIN
  MANAGER
  AGENT
  DISPATCHER
  FLEET_TECH
  DRIVER
  CLIENT
}

// Phase 6.5 — data-scope axis. TEAM (default) is "see the whole
// org's pipeline / orders / jobs / inquiries"; OWN is "see only
// rows where I'm the agent / assignee." Independent of role and
// of User.salesOnly — surface and data axes are separate.
enum DataScope {
  TEAM
  OWN
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  role      UserRole  @default(AGENT)
  // Phase 6.5 — surface scoping. AGENTs split into accounting (Ana)
  // and sales-only (Jose, Oliver). When salesOnly is true, the
  // permissions layer overrides off the operational sections (fleet,
  // dispatch, maintenance, scheduling, inventory, sub-rentals, the
  // bookings-gated tools) AND billing. Ana stays salesOnly=false so
  // her billing access is preserved. Separate from `dataScope` —
  // surface vs data are independent axes.
  salesOnly Boolean   @default(false) @map("sales_only")
  // Phase 6.5 — data scoping. TEAM sees the whole org's pipeline /
  // orders / jobs / inquiries; OWN is restricted to rows where the
  // requesting user is the agent (or, for inquiries, the assignee).
  // Server-side list endpoints honor this via the requireScope helper.
  // Default TEAM preserves today's behavior for every existing user.
  dataScope DataScope @default(TEAM) @map("data_scope")
  // Client-facing title (e.g. "COO", "Owner", "Sales Lead"). Separate from
  // `role` which is access-control / permission scope. The portal Job Page
  // shows displayTitle on the "Your SirReel Team" card; if null, the card
  // falls back to a generic label.
  displayTitle String? @map("display_title") @db.VarChar(60)
  phone     String?   @db.VarChar(30)
  avatarUrl String?   @map("avatar_url")
  location  Location? // Home base
  isActive  Boolean   @default(true) @map("is_active")

  // Agent-shareable public-intake handle. Lowercased first name by
  // convention (e.g. "jose", "oliver") — populated by the seed script
  // at scripts/seed-agent-slugs.ts. Used to attribute web-form
  // inquiries: /intake/<publicSlug> sets Inquiry.assignedToId to this
  // user on submit (validated server-side: isActive + role=AGENT).
  publicSlug String? @unique @map("public_slug")

  // Link to person if client portal user
  personId String? @unique @map("person_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Relations
  person              Person?             @relation("ContactUser", fields: [personId], references: [id])
  assignedPeople      Person[]            @relation("PersonAgent")
  agentBookings       Booking[]           @relation("BookingAgent")
  defaultForCompanies Company[]           @relation("DefaultAgent")
  emailAccounts       EmailAccount[]
  inspections         Inspection[]        @relation("InspectedBy")
  checkoutsProcessed  CheckoutRecord[]    @relation("CheckedOutBy")
  maintenanceCreated  MaintenanceRecord[] @relation("MaintCreatedBy")
  assignedClaims      InsuranceClaim[]    @relation("ClaimAssignee")
  uploadedDocs        ClaimDocument[]     @relation("DocUploader")
  timelineActions     ClaimTimeline[]     @relation("TimelineActor")
  reviewedClaimMail   ClaimMail[]         @relation("ClaimMailReviewer")
  createdOrderDiscounts OrderDiscount[]   @relation("OrderDiscountCreator")
  createdIncidents      Incident[]        @relation("IncidentCreator")
  // HR back-relations. employee is the 0-or-1 Employee row for staff
  // who happen to also have an HQ login — most do. reviewedHrMail is
  // every HR triage decision this user stamped. Access to HR data
  // itself is gated by src/lib/hr/allowlist.ts, NOT by these
  // relations — having a login + an Employee row does NOT imply
  // permission to see other employees' HR mail.
  employee            Employee?           @relation("EmployeeUserLink")
  reviewedHrMail      HrMail[]            @relation("HrMailReviewer")
  aiOverrides         AiDecision[]        @relation("AiOverrider")
  auditActions        AuditLog[]
  accounts            Account[]
  sessions            Session[]

  agentOrders     Order[]    @relation("OrderAgent")
  agentActivities Activity[] @relation("ActivityAgent")
  jobsAsAgent     Job[]      @relation("JobAgent")
  lotChecks       LotCheck[] @relation("LotCheckedBy")

  uploadedContractReviews ContractReview[] @relation("ContractReviewUploader")
  decidedContractReviews  ContractReview[] @relation("ContractReviewDecider")
  counterPdfsGenerated    ContractReview[] @relation("CounterPdfGenerator")
  changeDecisionsDecided  ReviewChangeDecision[] @relation("ChangeDecisionDecider")
  uploadedCoiChecks       CoiCheck[]       @relation("CoiCheckUploader")
  decidedCoiChecks        CoiCheck[]       @relation("CoiCheckDecider")
  assignedInquiries       Inquiry[]        @relation("InquiryAssignedTo")

  followUpsSent    QuoteFollowUp[] @relation("FollowUpSentBy")
  followUpsSkipped QuoteFollowUp[] @relation("FollowUpSkippedBy")

  // Phase 2 warehouse lane.
  pickListsAssigned   PickList[]     @relation("PickListAssignedTo")
  pickListItemsPicked PickListItem[] @relation("PickListItemPickedBy")

  // Phase 5 commit 3 — native payment recording.
  paymentsRecorded Payment[] @relation("PaymentRecorder")
  paymentsVoided   Payment[] @relation("PaymentVoider")

  @@map("users")
}

