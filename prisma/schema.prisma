  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

model Inspection {
  id                  String           @id @default(uuid())
  assetId             String           @map("asset_id")
  bookingAssignmentId String?          @map("booking_assignment_id")
  type                InspectionType
  inspectedBy         String           @map("inspected_by")
  inspectionDate      DateTime         @map("inspection_date")
  overallCondition    VehicleCondition @map("overall_condition")
  mileageAtInspection Int?             @map("mileage_at_inspection")
  fuelLevel           String?          @map("fuel_level")

  // DamageID
  damageIdReportUrl String? @map("damage_id_report_url")
  damageIdRef       String? @map("damage_id_ref")

  newDamageFound Boolean @default(false) @map("new_damage_found")
