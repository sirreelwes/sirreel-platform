// ═══════════════════════════════════════════════════════════════
// SIRREEL PLATFORM — PRISMA SCHEMA
// 21 Tables · 11 Sections · All Relationships Defined
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// 1. FLEET & ASSETS
// ═══════════════════════════════════════

enum Location {
  LANKERSHIM
  NAPA
  UTAH
  CHESTNUT // legacy
  LIMA // legacy
  ON_RENTAL
  IN_TRANSIT
  BODY_SHOP
  HIGH_TECH
}

enum AssetStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  IN_TRANSIT
  WAREHOUSE
  RETIRED
  SOLD
  STOLEN
}

enum AssetTier {
  PREMIUM
  STANDARD
  ECONOMY
}

enum Region {
  LA
  NORCAL
  UTAH
}

model AssetCategory {
  id             String              @id @default(uuid())
  name           String // "Cube Truck", "PopVan", "Studios"
  slug           String              @unique // "cube-truck"
  totalUnits     Int                 @map("total_units")
  dailyRate      Decimal             @map("daily_rate") @db.Decimal(10, 2)
  weeklyRate     Decimal?            @map("weekly_rate") @db.Decimal(10, 2)
  minRentalHours Int                 @default(24) @map("min_rental_hours")
  maxRentalDays  Int                 @default(365) @map("max_rental_days")
  region         Region              @default(LA)
  isPublished    Boolean             @default(true) @map("is_published")
  description    String?             @db.Text
  imageUrl       String?             @map("image_url")
  sortOrder      Int                 @default(0) @map("sort_order")
  // Phase 2 sales pipeline — see InventoryItem for semantics.
  aliases        String[]            @default([])
  department     LineItemDepartment
  // Defensive RW columns (May 2026). The May spike doesn't write to
  // AssetCategory rows, but Phase 4 may map RW Categories ↔ SirReel
  // AssetCategory; columns are in place to avoid a re-migration.
  needsReview    Boolean             @default(false) @map("needs_review")
  rwLastSyncedAt DateTime?           @map("rw_last_synced_at")
  rwId           String?             @map("rw_id")

  // Integration IDs
  planyoResourceId   Int?    @unique @map("planyo_resource_id")
  rentalworksCategId String? @map("rentalworks_category_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  assets         Asset[]
  bookingItems   BookingItem[]
  orderLineItems OrderLineItem[]

  @@index([rwId])
  @@index([needsReview])
  @@map("asset_categories")
}

model Asset {
  id         String      @id @default(uuid())
  categoryId String      @map("category_id")
  unitName   String      @map("unit_name") // "18", "Sprinter #2 (A)", "Lankershim Studio"
  status     AssetStatus @default(AVAILABLE)
  location   Location    @default(LANKERSHIM)
  tier       AssetTier   @default(STANDARD)
  // 1–5 age/condition class for the fleet-assignment optimizer.
  // Distinct from the legacy `tier` field above (3-bucket marketing
  // tier: PREMIUM/STANDARD/ECONOMY). equipmentTier matches
  // ProductionTypeProfile.tier pools: tier=5 routes to newest-gear
  // pool, tier=1 to oldest. Nullable until the fleet team backfills
  // the 5-bucket classification across the inventory.
  equipmentTier Int? @map("equipment_tier")

  // Vehicle details
  vin          String? @db.VarChar(20)
  licensePlate String? @map("license_plate") @db.VarChar(20)
  year         Int?
  make         String? @db.VarChar(50)
  model        String? @db.VarChar(50)
  mileage      Int?

  // Valuation (for insurance claims)
  purchasePrice      Decimal? @map("purchase_price") @db.Decimal(12, 2)
  currentValue       Decimal? @map("current_value") @db.Decimal(12, 2)
  // CRH §6.2 — INTERNAL ONLY. Never surface in any client-facing endpoint.
  // The portal data endpoint's Prisma select clause is the audit checkpoint;
  // any new selector that touches `assets` must explicitly exclude these.
  insurancePolicyNum String?  @map("insurance_policy_num") @db.VarChar(50)
  insuranceCardUrl   String?  @map("insurance_card_url")

  // CRH DOT packet (client-facing). Registration + BIT certificate live on
  // the Asset because that's our existing Vehicle equivalent in this
  // schema. Each has an expiry the daily cron uses to alert fleet (Julian
  // + Chris) at 30 days out, and a soft-block guard on job assignment when
  // the rental return date falls after the doc expires.
  registrationUrl         String?   @map("registration_url")
  registrationExpiresAt   DateTime? @map("registration_expires_at") @db.Date
  bitCertificateUrl       String?   @map("bit_certificate_url")
  bitCertificateExpiresAt DateTime? @map("bit_certificate_expires_at") @db.Date

  // Integration IDs
  rentalworksAssetId String? @map("rentalworks_asset_id")
  damageIdRef        String? @map("damage_id_ref")

  notes    String? @db.Text
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  category           AssetCategory       @relation(fields: [categoryId], references: [id])
  bookingAssignments BookingAssignment[]
  maintenanceRecords MaintenanceRecord[]
  dispatchTasks      DispatchTask[]
  inspections        Inspection[]
  insuranceClaims    InsuranceClaim[]
  incidents          Incident[]
  checkoutRecords    CheckoutRecord[]
  lotChecks          LotCheck[]

  @@map("assets")
}

// ═══════════════════════════════════════
// 2. CLIENTS & CRM
// ═══════════════════════════════════════

enum ClientTier {
  VIP
  PREFERRED
  STANDARD
  NEW
}

/// How often a client negotiates rates. Set on Company; drives the
/// "Negotiates" badge on lists + the Discount profile section on
/// the client file. NONE = doesn't negotiate; ALWAYS = expects a
/// discount on every quote.
enum DiscountTendency {
  NONE
  OCCASIONAL
  FREQUENT
  ALWAYS
}

enum ProductionType {
  FILM
  TV
  COMMERCIAL
  MUSIC_VIDEO
  CORPORATE
  EVENT_PLANNER
  OTHER
}

// Lookup table for production-type metadata that drives the
// future fleet-assignment optimizer (commit 1 of the production-
// type tiering work, May 2026). Distinct from the legacy
// ProductionType enum above — that enum is a free-form category
// label on Job / Company; this table carries the structured tier +
// sales-mode + price-sensitivity profile used by routing logic.
// The two coexist; later commits will migrate writers across.
model ProductionTypeProfile {
  id               String   @id @default(uuid())
  name             String   @unique
  slug             String   @unique
  tier             Int      // 1–5; 5 = newest-gear pool, 1 = oldest
  upsellPropensity Int      @map("upsell_propensity") // 1–5; 1 = none, 5 = high
  priceSensitivity Int      @map("price_sensitivity") // 1–5; 1 = premium-tolerant, 5 = very sensitive
  salesMode        String   @map("sales_mode")        // WHITE_GLOVE | HIGHER_TOUCH | SEMI_AUTO | LIGHT_TOUCH | FULL_AUTO
  sortOrder        Int      @default(0) @map("sort_order")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  jobs                Job[]     @relation("JobProductionTypeProfile")
  mostCommonForCompanies Company[] @relation("CompanyMostCommonProductionTypeProfile")

  @@map("production_type_profiles")
}

// Customer-facing vehicle catalog tile lookup for the unified
// production-order shop (/order/supplies). Distinct from
// AssetCategory (the internal fleet-bucket grouping that
// schedules and assigns specific Assets) — VehicleCategory rows
// are the cards a client sees and picks from, with marketing copy
// and a "from $X/day" price hint. The internal Asset.categoryId
// linkage stays separate; a fleet ops handoff later maps a
// VehicleCategory pick to a specific AssetCategory pool.
//
// dailyRate is the customer-facing "from" rate; null = price-on-
// quote (don't render a price hint). photoUrl is admin-managed;
// null renders a graceful placeholder.
model VehicleCategory {
  id         String   @id @default(uuid())
  name       String   @unique
  slug       String   @unique
  subtitle   String?
  photoUrl   String?  @map("photo_url")
  dailyRate  Decimal? @map("daily_rate") @db.Decimal(10, 2)
  sortOrder  Int      @default(0) @map("sort_order")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("vehicle_categories")
}

model Company {
  id            String         @id @default(uuid())
  name          String
  website       String?
  industry      ProductionType @default(OTHER)
  tier          ClientTier     @default(NEW)
  totalSpend    Decimal        @default(0) @map("total_spend") @db.Decimal(12, 2)
  totalBookings Int            @default(0) @map("total_bookings")

  // Cached mode of productionTypeProfileId across this company's Jobs.
  // Recomputed by lib/companies/recomputeMostCommonProductionTypeProfile.
  // Nullable — companies with zero jobs (or no profile-tagged jobs) get
  // null. Not maintained by the booking flow yet; the recompute helper
  // is called manually from a backfill script in this commit. Wiring
  // into the Job create/update path lands in a later commit.
  mostCommonProductionTypeProfileId String? @map("most_common_production_type_profile_id")

  // Default agent
  defaultAgentId String? @map("default_agent_id")

  orders     Order[]
  activities Activity[]

  // Insurance (for claims — client's production insurance)
  insuranceCarrier   String?   @map("insurance_carrier")
  insurancePolicyNum String?   @map("insurance_policy_num")
  insuranceContact   String?   @map("insurance_contact")
  coiOnFile          Boolean   @default(false) @map("coi_on_file")
  coiExpiry          DateTime? @map("coi_expiry")
  coiDocumentUrl     String?   @map("coi_document_url")

  // Integration
  rentalworksCustomerId String? @map("rentalworks_customer_id")

  billingEmail   String? @map("billing_email")
  billingAddress String? @map("billing_address") @db.Text
  notes          String? @db.Text

  // Discount / negotiation profile — institutional memory on this
  // client. discountTendency drives the "Negotiates" badge on the
  // CRM list (next pass — wired in the Needs-attention strip work).
  // typicalDiscountPct is what they usually angle for (15 = "15%").
  // discountNotes is free-text context (e.g. "always asks for free
  // delivery"). All three are agent-set, no derivation today.
  discountTendency    DiscountTendency @default(NONE)  @map("discount_tendency")
  typicalDiscountPct  Int?             @map("typical_discount_pct")
  discountNotes       String?          @map("discount_notes") @db.Text

  // ── CRH: Company-level paperwork (institutional memory) ────────────────
  // Annual MSA (Master Services Agreement). When `annualAgreementApprovedAt`
  // is set AND `annualAgreementExpiresAt` is still in the future, new jobs
  // for this company skip the per-job agreement signing flow.
  annualAgreementUrl           String?   @map("annual_agreement_url")
  annualAgreementEffectiveDate DateTime? @map("annual_agreement_effective_date")
  annualAgreementExpiresAt     DateTime? @map("annual_agreement_expires_at")
  annualAgreementSignedBy      String?   @map("annual_agreement_signed_by")
  annualAgreementApprovedBy    String?   @map("annual_agreement_approved_by")
  annualAgreementApprovedAt    DateTime? @map("annual_agreement_approved_at")

  // Annual COI (Certificate of Insurance). Parallel structure to the MSA;
  // additionally stores the coverage limits so the CRH job-creation flow
  // can validate per-job requirements against the annual policy.
  annualCoiUrl                 String?   @map("annual_coi_url")
  annualCoiEffectiveDate       DateTime? @map("annual_coi_effective_date")
  annualCoiExpiresAt           DateTime? @map("annual_coi_expires_at")
  annualCoiCoverageGL          Decimal?  @map("annual_coi_coverage_gl") @db.Decimal(14, 2)
  annualCoiCoverageAuto        Decimal?  @map("annual_coi_coverage_auto") @db.Decimal(14, 2)
  annualCoiApprovedBy          String?   @map("annual_coi_approved_by")
  annualCoiApprovedAt          DateTime? @map("annual_coi_approved_at")

  // Negotiated terms. When set, future Quote/Job flows render a banner and
  // use this PDF as the baseline (not the standard SirReel template). The
  // `summary` is the plain-English diff future-Wes reads to remember WHAT
  // was negotiated, not just THAT it was.
  negotiatedTermsUrl           String?   @map("negotiated_terms_url")
  negotiatedTermsSummary       String?   @map("negotiated_terms_summary") @db.Text
  negotiatedTermsNegotiatedAt  DateTime? @map("negotiated_terms_negotiated_at")
  negotiatedTermsApprovedBy    String?   @map("negotiated_terms_approved_by")
  negotiatedTermsApprovedAt    DateTime? @map("negotiated_terms_approved_at")
  negotiatedTermsActiveAsOf    DateTime? @map("negotiated_terms_active_as_of")
  negotiatedTermsReviewDueDate DateTime? @map("negotiated_terms_review_due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  defaultAgent    User?            @relation("DefaultAgent", fields: [defaultAgentId], references: [id])
  mostCommonProductionTypeProfile ProductionTypeProfile? @relation("CompanyMostCommonProductionTypeProfile", fields: [mostCommonProductionTypeProfileId], references: [id])
  affiliations    Affiliation[]
  bookings        Booking[]
  drivers         Driver[]
  insuranceClaims InsuranceClaim[]
  incidents       Incident[]
  emailMessages   EmailMessage[]
  jobs            Job[]
  contractReviews ContractReview[]
  coiChecks       CoiCheck[]
  inquiries       Inquiry[]

  @@index([mostCommonProductionTypeProfileId])
  @@map("companies")
}

enum PersonRole {
  UPM
  PRODUCER
  LINE_PRODUCER
  PRODUCTION_COORDINATOR
  PRODUCTION_SUPERVISOR
  TRANSPORTATION_COORDINATOR
  ART_COORDINATOR
  COORDINATOR
  OWNER
  OTHER
}

model Person {
  id        String     @id @default(uuid())
  firstName String     @map("first_name")
  lastName  String     @map("last_name")
  email     String     @unique
  phone     String?    @db.VarChar(30)
  mobile    String?    @db.VarChar(30)
  role      PersonRole @default(OTHER)
  tier      ClientTier @default(NEW)

  // Assigned agent at SirReel
  assignedAgentId String? @map("assigned_agent_id")

  // Lifetime stats (across ALL companies)
  totalSpend    Decimal    @default(0) @map("total_spend") @db.Decimal(12, 2)
  totalBookings Int        @default(0) @map("total_bookings")
  activities    Activity[]
  lastBookingAt DateTime?  @map("last_booking_at")

  // "Works with" — e.g. UPM's regular coordinator
  worksWithId String? @map("works_with_id")

  // Integration
  planyoUserId Int? @map("planyo_user_id")

  notes    String? @db.Text
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  assignedAgent    User?          @relation("PersonAgent", fields: [assignedAgentId], references: [id])
  worksWith        Person?        @relation("WorksWith", fields: [worksWithId], references: [id])
  worksWithBack    Person[]       @relation("WorksWith")
  affiliations     Affiliation[]
  bookings         Booking[]      @relation("BookingContact")
  referredBookings Booking[]      @relation("BookingReferrer")
  user             User?          @relation("ContactUser")
  emailMessages    EmailMessage[]
  jobContacts      JobContact[]
  orderContacts    Order[]        @relation("OrderJobContact")
  inquiries        Inquiry[]      @relation("InquiryContact")
  portalAccesses   PortalAccess[] @relation("PortalAccessContact")
  personSessions   PersonSession[]

  @@map("people")
}

model Affiliation {
  id             String      @id @default(uuid())
  personId       String      @map("person_id")
  companyId      String      @map("company_id")
  productionName String?     @map("production_name") // "Stranger Things S5", "MI:7"
  roleOnShow     PersonRole? @map("role_on_show")
  startDate      DateTime?   @map("start_date") @db.Date
  endDate        DateTime?   @map("end_date") @db.Date
  isCurrent      Boolean     @default(true) @map("is_current")

  // Revenue from this person+company combo
  totalSpend    Decimal @default(0) @map("total_spend") @db.Decimal(12, 2)
  totalBookings Int     @default(0) @map("total_bookings")

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  person  Person  @relation(fields: [personId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([personId, companyId, productionName])
  @@map("affiliations")
}

// ═══════════════════════════════════════
// 3. DRIVERS
// ═══════════════════════════════════════

enum DriverType {
  EXTERNAL // Production company's driver
  INTERNAL // SirReel driver (Wes, Hugo, etc.)
}

model Driver {
  id        String  @id @default(uuid())
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  phone     String? @db.VarChar(30)
  email     String?

  // License
  licenseNumber   String?   @map("license_number") @db.VarChar(30)
  licenseState    String?   @map("license_state") @db.VarChar(5)
  licenseExpiry   DateTime? @map("license_expiry")
  licensePhotoUrl String?   @map("license_photo_url")

  type      DriverType @default(EXTERNAL)
  companyId String?    @map("company_id") // Which production sent them (external drivers)

  // Tracking
  totalCheckouts  Int     @default(0) @map("total_checkouts")
  damageIncidents Int     @default(0) @map("damage_incidents")
  flagged         Boolean @default(false) // Auto-set if damage history
  flagReason      String? @map("flag_reason") @db.Text

  notes    String? @db.Text
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company         Company?         @relation(fields: [companyId], references: [id])
  checkoutRecords CheckoutRecord[]
  dispatchTasks   DispatchTask[]   @relation("TaskDriver")

  @@map("drivers")
}

// ═══════════════════════════════════════
// 4. BOOKINGS & RESERVATIONS
// ═══════════════════════════════════════

enum BookingStatus {
  REQUEST
  AI_REVIEW
  PENDING_APPROVAL
  CONFIRMED
  ACTIVE
  RETURNED
  CANCELLED
  ARCHIVED
}

enum BookingPriority {
  URGENT
  HIGH
  STANDARD
  LOW
}

enum BookingSource {
  WEBSITE
  PHONE
  EMAIL
  AGENT_DIRECT
  AI_AUTO
  /// Rows created by the Planyo orphan backfill (one-off, May 2026,
  /// run from the timeline-booking-truth branch before it merged).
  /// Listed here so main's schema reflects the live DB; not used by
  /// new code paths. 74 rows currently carry this source.
  PLANYO_BACKFILL
}

enum UnionStatus {
  UNION
  NON_UNION
  UNKNOWN
}

model Booking {
  id             String          @id @default(uuid())
  bookingNumber  String          @unique @map("booking_number") // SR-2026-0042
  companyId      String          @map("company_id")
  personId       String          @map("person_id") // Who called / requested (coordinator or UPM)
  referredById   String?         @map("referred_by_id") // The UPM, if a coordinator called on their behalf
  agentId        String          @map("agent_id")
  /// Optional FK back to the SirReel HQ-native Job (billing-side). New
  /// holds created via +Hold pick or create a Job and stamp this. NULL
  /// on legacy Bookings (Planyo-imported, pre-Job-linkage) — Order is
  /// still the only required path from Booking → Job. The native
  /// scheduling engine does NOT read this column.
  jobId          String?         @map("job_id")
  productionName String?         @map("production_name") // "Stranger Things S5" — legacy free-text; new holds skip it
  jobName        String          @map("job_name")
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime        @map("end_date") @db.Date
  status         BookingStatus   @default(REQUEST)
  priority       BookingPriority @default(STANDARD)
  totalPrice     Decimal?        @map("total_price") @db.Decimal(12, 2)
  depositAmount  Decimal?        @map("deposit_amount") @db.Decimal(10, 2)
  depositPaid    Boolean         @default(false) @map("deposit_paid")

  // Compliance
  rentalAgreement Boolean     @default(false) @map("rental_agreement")
  coiReceived     Boolean     @default(false) @map("coi_received")
  unionStatus     UnionStatus @default(UNKNOWN) @map("union_status")

  // Delivery
  deliveryAddress String? @map("delivery_address") @db.Text
  deliveryTime    String? @map("delivery_time")
  pickupAddress   String? @map("pickup_address") @db.Text
  pickupTime      String? @map("pickup_time")

  // Notes
  notes      String? @db.Text
  adminNotes String? @map("admin_notes") @db.Text

  // AI
  aiAnalysisId String? @map("ai_analysis_id")

  // Integration
  rentalworksOrderId   String? @map("rentalworks_order_id")
  rentalworksInvoiceId String? @map("rentalworks_invoice_id")
  invoiceStatus        String? @map("invoice_status") // not_created, draft, sent, paid, overdue

  /// Planyo cart_id this Booking was imported from. Cart-level
  /// idempotency anchor for scheduling-planyo-migration.ts re-runs:
  /// when Planyo gains a new reservation on an already-imported cart,
  /// the script looks up the existing Booking via this @unique field
  /// and APPENDS new BookingItems instead of creating a duplicate
  /// Booking. NULL on Bookings created via the +Hold flow.
  planyoCartId         String? @unique @map("planyo_cart_id")

  source BookingSource @default(PHONE)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  confirmedAt DateTime? @map("confirmed_at")
  returnedAt  DateTime? @map("returned_at")
  /// Soft-archive marker set by POST /api/bookings/[id]/archive. The
  /// /bookings page filters `archivedAt IS NULL` by default; restoring
  /// clears the field. Related rows (PaperworkRequest, SignedAgreement
  /// via Orders, PortalAccess, etc.) are left untouched — archive is a
  /// visibility-only flag, not a cascade. A separate ADMIN-only purge
  /// path will handle hard deletion later.
  archivedAt  DateTime? @map("archived_at")

  // Relations
  company           Company            @relation(fields: [companyId], references: [id])
  person            Person             @relation("BookingContact", fields: [personId], references: [id])
  referredBy        Person?            @relation("BookingReferrer", fields: [referredById], references: [id])
  agent             User               @relation("BookingAgent", fields: [agentId], references: [id])
  job               Job?               @relation(fields: [jobId], references: [id])
  items             BookingItem[]
  dispatchTasks     DispatchTask[]
  insuranceClaims   InsuranceClaim[]
  aiDecisions       AiDecision[]
  paperworkRequests PaperworkRequest[]
  orders            Order[]
  activities        Activity[]
  reservations      Reservation[]

  @@index([jobId])
  @@map("bookings")
}

// Planyo-mirror rows from the timeline-booking-truth backfill. Kept in
// schema so main matches the live DB; not consumed by current code
// paths. The native scheduling engine does NOT use this model — it
// reads from BookingItem + BookingAssignment.
model Reservation {
  id                  String            @id @default(uuid())
  bookingId           String?           @map("booking_id")
  booking             Booking?          @relation(fields: [bookingId], references: [id])

  unitName            String            @map("unit_name")
  category            String?

  startTime           DateTime          @map("start_time")
  endTime             DateTime          @map("end_time")

  status              ReservationStatus @default(HOLD)
  source              ReservationSource @default(PLANYO)

  planyoReservationId String?           @unique @map("planyo_reservation_id")
  planyoCartId        String?           @map("planyo_cart_id")
  planyoCompany       String?           @map("planyo_company")
  planyoJobName       String?           @map("planyo_job_name")
  planyoAgent         String?           @map("planyo_agent")
  planyoCustomerName  String?           @map("planyo_customer_name")
  planyoCustomerEmail String?           @map("planyo_customer_email")
  planyoCustomerPhone String?           @map("planyo_customer_phone")
  notes               String?           @db.Text

  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([unitName])
  @@index([startTime, endTime])
  @@index([planyoCartId])
  @@map("reservations")
}

enum ReservationStatus {
  CONFIRMED
  HOLD
  CANCELLED
}

enum ReservationSource {
  PLANYO
  NATIVE
}

enum BookingItemStatus {
  REQUESTED
  ASSIGNED
  SUBSTITUTED
  UNFULFILLED
}

model BookingItem {
  id         String            @id @default(uuid())
  bookingId  String            @map("booking_id")
  categoryId String            @map("category_id")
  quantity   Int
  dailyRate  Decimal           @map("daily_rate") @db.Decimal(10, 2)
  lineTotal  Decimal?          @map("line_total") @db.Decimal(10, 2)
  status     BookingItemStatus @default(REQUESTED)
  /// Hold rank — 1 = primary, ≥2 = backup ("2nd hold" / "3rd hold").
  /// Backups can overlap a category at capacity; they do NOT consume
  /// availableToHold. Manual promotion only — when a primary
  /// releases, an agent surfaces the next-rank backup explicitly.
  /// Replaces the Planyo "X - 2ND HOLD" placeholder workaround.
  holdRank   Int               @default(1) @map("hold_rank")
  notes      String?           @db.Text

  // Relations
  booking     Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  category    AssetCategory       @relation(fields: [categoryId], references: [id])
  assignments BookingAssignment[]

  @@map("booking_items")
}

