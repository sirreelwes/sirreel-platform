  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items InventoryItem[]

  @@map("inventory_categories")
}

// Editable replacement for the legacy `Location` enum on InventoryItem.
// `code` mirrors the old enum value (e.g. "LANKERSHIM") so the backfill
// can map old → new without ambiguity.
model InventoryLocation {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items InventoryItem[]

  @@map("inventory_locations")
}

model InventoryItem {
  id              String              @id @default(uuid())
  // Nullable since the May 2026 RW import — auto-created rows from RW
  // start with no SirReel category until the admin reassigns. Existing
  // hand-curated rows always have one.
  categoryId      String?             @map("category_id")
  code            String              @unique
  description     String?
  dailyRate       Decimal             @default(0) @map("daily_rate") @db.Decimal(10, 2)
  weeklyRate      Decimal             @default(0) @map("weekly_rate") @db.Decimal(10, 2)
  qtyOwned        Int                 @default(0) @map("qty_owned")
  replacementCost Decimal?            @map("replacement_cost") @db.Decimal(10, 2)
  imageUrl        String?             @map("image_url")
  // Phase 2 sales pipeline. `aliases` are colloquial synonyms ("walkies" →
  // CP200 Radio) handed to the AI extractor as catalog context and used
  // server-side for fallback alias-tokenized matching. `department` is the
  // catalog-side authority — when an OrderLineItem matches this product,
  // the line item's department is overridden from this field.
  aliases         String[]            @default([])
  department      LineItemDepartment
  // Default LineItemType for this catalog item — inherited by
  // OrderLineItem when the line is created from a catalog match
  // (overridable per-line). EQUIPMENT for unit=day rentals,
  // EXPENDABLE for unit=ea consumables. The new-quote createQuote
  // path may still re-derive at create time for legacy callers.
  type            LineItemType        @default(EQUIPMENT)
  // RentalWorks enrichment (May 2026 spike). The first four columns are
  // populated from RW Items grouped by InventoryId. needsReview flags
  // auto-created rows where Wes hasn't yet picked an InventoryCategory /
  // confirmed the dept guess. rwLastSyncedAt + rwId track the last RW
  // pull so re-syncs can pick up where they left off.
  manufacturer    String?
  model           String?
  specs           String?             @db.Text
  dimensions      String?
  needsReview     Boolean             @default(false) @map("needs_review")
  rwLastSyncedAt  DateTime?           @map("rw_last_synced_at")
  rwId            String?             @map("rw_id")
  // Whether the item appears in the client-facing supply ordering
  // catalog. Defaults false so RW-imported rows stay out of the public
  // surface until an operator (or the seed script) opts them in. The
  // seed flips this for items reconciled against the Production
  // Supplies PDF; everything else stays hidden.
  publicVisible   Boolean             @default(false) @map("public_visible")
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  category   InventoryCategory? @relation(fields: [categoryId], references: [id])
  lineItems  OrderLineItem[]
  subRentals SubRental[]
  location   Location           @default(LANKERSHIM)

  // New editable-location FK. Coexists with the legacy enum during transition;
  // app reads/writes prefer this when present.
  locationId  String?            @map("location_id")
  locationRef InventoryLocation? @relation(fields: [locationId], references: [id])

  @@index([rwId])
  @@index([needsReview])
  @@index([locationId])
  @@map("inventory_items")
}

model Order {
  id              String           @id @default(uuid())
  orderNumber     String           @unique @map("order_number")
  bookingId       String?          @map("booking_id")
  companyId       String           @map("company_id")
  agentId         String           @map("agent_id")
  status          OrderStatus      @default(DRAFT)
  quoteStatus     OrderQuoteStatus @default(DRAFT) @map("quote_status")
  description     String?          @db.Text
  startDate       DateTime?        @map("start_date") @db.Date
  endDate         DateTime?        @map("end_date") @db.Date
  subtotal        Decimal          @default(0) @db.Decimal(12, 2)
  taxRate         Decimal          @default(0) @map("tax_rate") @db.Decimal(5, 4)
  taxAmount       Decimal          @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal          @default(0) @db.Decimal(12, 2)
  // Booked-value snapshot — captured atomically when the order is BOOKED
  // (Phase 1 / commit 3). These are the second of the three canonical
  // money numbers per order-lifecycle-spec (quote estimate → booked
  // value → final invoice). They are write-once: never overwritten by
  // post-booking edits to subtotal/total, and never collapsed into the
  // Invoice columns. Null until the order has been booked.
  bookedSubtotal  Decimal?         @map("booked_subtotal") @db.Decimal(12, 2)
  bookedTaxAmount Decimal?         @map("booked_tax_amount") @db.Decimal(12, 2)
  bookedTotal     Decimal?         @map("booked_total") @db.Decimal(12, 2)
  bookedAt        DateTime?        @map("booked_at")
  // Phase 3 lifecycle: stamped when the fleet lane is physically
  // ready (manually via /api/orders/[id]/fleet-ready for now; will be
  // stamped automatically when the digital fleet checkout flow lands).
  // The LOADED_READY rollup treats fleetReadyAt non-null as fleet-side
  // terminal. Null = fleet side still pending OR no fleet lines.
  fleetReadyAt    DateTime?        @map("fleet_ready_at")
  quoteSentAt     DateTime?        @map("quote_sent_at")
  quoteAcceptedAt DateTime?        @map("quote_accepted_at")
  quoteExpDays    Int              @default(7) @map("quote_exp_days")
  // Sales-stage timestamps. Stamped by the sync helper when quoteStatus
  // transitions; sentAt/wonAt/lostAt are write-once (only set if currently
  // null). expiresAt is reserved for a future auto-expiry mechanism.
  sentAt          DateTime?        @map("sent_at")
  expiresAt       DateTime?        @map("expires_at")
  wonAt           DateTime?        @map("won_at")
  lostAt          DateTime?        @map("lost_at")
  notes           String?          @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Locked enum reason populated when an Order transitions to LOST. The column
  // was previously free-text but had zero rows in production at the time of
  // the CRH cutover, so it was switched to a typed enum to drive lost-quote
  // reporting and re-engagement cadence eligibility.
  lostReason LostReason? @map("lost_reason")

  // Client Relationship Hub (CRH) cadence state. `cadenceState` mirrors
  // Order.status but at a finer grain — it tracks where the order sits in
  // the email cadence ladder (quote silence, acknowledged, discussing,
  // booked, in-progress, ...). The cron-driven CadenceEventRunner advances
  // it and emits emails based on the state machine in the CRH brief.
  cadenceState           CadenceState @default(QUOTE_DRAFT) @map("cadence_state")
  cadencePausedUntil     DateTime?    @map("cadence_paused_until")
  cadenceManualOverride  Boolean      @default(false) @map("cadence_manual_override")

  // Captures the pickup date as it stood when the order was marked LOST.
  // Useful for re-engagement reporting (how close to pickup did we lose them).
  pickupDateAtLoss       DateTime?    @map("pickup_date_at_loss")

  // Re-engagement (post-LOST) touchpoint tracking. Set by the
  // LOST_REENGAGEMENT_2W cadence event when it fires; flipped to true when
  // the client responds (any inbound reply detected by Gmail integration).
  reengagementSentAt     DateTime?    @map("reengagement_sent_at")
  reengagementResponded  Boolean      @default(false) @map("reengagement_responded")

  // Client-facing portal URL slug. Declared nullable because `prisma db push`
  // cannot add a non-null TEXT column to existing rows without a SQL default
  // (Prisma's @default(uuid()) runs client-side). New rows always get a slug
  // via the @default(uuid()); a one-time backfill populates pre-existing rows.
  // Once every row has a value, the application layer can treat this as
  // effectively non-null.
  portalSlug             String?      @unique @default(uuid()) @map("portal_slug")
  portalCreatedAt        DateTime     @default(now()) @map("portal_created_at")
  portalSunsetAt         DateTime?    @map("portal_sunset_at")

  // Client-facing Quote PDF (mirrors the contract review counter-PDF
  // pattern: blob key + url + timestamp, replace-on-regenerate). PDF is
  // generated when the agent clicks "Create Quote" on /orders/new-quote
  // and lands in Vercel Blob behind auth.
  quotePdfKey         String?   @map("quote_pdf_key")
  quotePdfUrl         String?   @map("quote_pdf_url")
  quotePdfGeneratedAt DateTime? @map("quote_pdf_generated_at")

  // Blind handoff flags — set on the order when the client picks up
  // their own unit (blindPickup) or returns it themselves (blindReturn)
  // without a SirReel rep present. When either flag is on, the matching
  // *Instructions text is what the agent typed for the client to see in
  // the portal (location, gate code, lockbox combination, where to
  // park, etc.). The Dispatch board surfaces blindReturn loudly on the
  // inbound lane so the unit doesn't sit unprocessed.
  blindPickup              Boolean @default(false) @map("blind_pickup")
  blindReturn              Boolean @default(false) @map("blind_return")
  blindPickupInstructions  String? @map("blind_pickup_instructions") @db.Text
  blindReturnInstructions  String? @map("blind_return_instructions") @db.Text

  // Phase 1b client-intake — set when this Order was added as an
  // "add-on" to an existing Job via the inquiry triage path (rather
  // than created alongside a new Job at quote time). Null on every
  // Order that was the FIRST order on its job. Drives the "Add-on"
  // chip on the order list + detail and the convertedOrder relation
  // back-link from the Inquiry it satisfied.
  addedToJobAt             DateTime? @map("added_to_job_at")

  booking      Booking?        @relation(fields: [bookingId], references: [id])
  company      Company         @relation(fields: [companyId], references: [id])
  agent        User            @relation("OrderAgent", fields: [agentId], references: [id])
  lineItems    OrderLineItem[]
  invoices     Invoice[]
  subRentals   SubRental[]
  followUps    QuoteFollowUp[]
  discounts    OrderDiscount[]
  incidents    Incident[]
  jobId        String          @map("job_id")
  jobContactId String?         @map("job_contact_id")

  job        Job     @relation(fields: [jobId], references: [id])
  jobContact Person? @relation("OrderJobContact", fields: [jobContactId], references: [id])

  // Was 1:1 before May 2026; now 1:many because an Order may need both a
  // RENTAL_AGREEMENT and a STAGE_CONTRACT. Callers that historically read
  // `order.signedAgreement` should switch to filtering on contractType, e.g.
  // `signedAgreements.find(a => a.contractType === 'RENTAL_AGREEMENT')`.
  signedAgreements   SignedAgreement[]
  stageBookingTerms  StageBookingTerms?
  cadenceEvents      CadenceEvent[]
  portalAccesses     PortalAccess[]
  emailDeliveries    EmailDelivery[]
  // 1-1 back-relation to the Inquiry that became this Order via the
  // add-on triage path. Mirrors Job.fromInquiry — Inquiry.convertedOrderId
  // is @unique so at most one Inquiry points here.
  fromInquiry        Inquiry?         @relation("ConvertedFromInquiryToOrder")
  // Phase 2 warehouse lane: zero-or-one PickList per Order, created at
  // book time iff the order has ≥1 WAREHOUSE-lane line item.
  pickList           PickList?

  @@index([jobId])
  @@index([quoteStatus, sentAt])
  @@index([cadenceState])
  @@map("sr_orders")
}

enum FollowUpStage {
  DAY_0 // legacy: EOD same day quote was sent (cron-generated, pipeline panel)
  DAY_1 // legacy: ~24h after send
  DAY_3 // legacy: ~72h after send

  // Mode A cadence values (May 2026). Anchored to quoteSentAt + expiresAt,
  // not a flat hour offset. See src/lib/sales/quoteCadence.ts for the
  // STAGE_N due-time math and gating. Agent-driven send from the order
  // detail panel — no cron auto-creation; rows are logged at send time.
  STAGE_1 // ~2 days after sent — "did the quote land?"
  STAGE_2 // ~halfway between sent and valid-until — "still planning these dates?"
  STAGE_3 // ~1–2 days before valid-until — "want to lock it in?"
}

enum FollowUpStatus {
  PENDING // due, awaiting agent action
  SENT    // agent sent the follow-up
  SKIPPED // agent dismissed without sending
  EXPIRED // quote moved out of SENT before agent acted (won/lost/draft)
}

// Cadence row generated by the hourly cron whenever a SENT quote crosses a
// threshold. Drafts are pre-composed; the agent reviews + sends from the
// pipeline. Unique on (orderId, stage) so cron runs are idempotent.
model QuoteFollowUp {
  id           String         @id @default(uuid())
  orderId      String         @map("order_id")
  stage        FollowUpStage
  dueAt        DateTime       @map("due_at")
  status       FollowUpStatus @default(PENDING)
  draftSubject String         @map("draft_subject")
  draftBody    String         @map("draft_body") @db.Text
  sentAt       DateTime?      @map("sent_at")
  sentById     String?        @map("sent_by_id")
  skippedAt    DateTime?      @map("skipped_at")
  skippedById  String?        @map("skipped_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sentBy    User? @relation("FollowUpSentBy", fields: [sentById], references: [id])
  skippedBy User? @relation("FollowUpSkippedBy", fields: [skippedById], references: [id])
  emailDeliveries EmailDelivery[]

  @@unique([orderId, stage])
  @@index([status, dueAt])
  @@map("quote_followups")
}

model OrderLineItem {
  id              String             @id @default(uuid())
  orderId         String             @map("order_id")
  sortOrder       Int                @default(0) @map("sort_order")
  type            LineItemType
  // Phase 1 sales pipeline: every line item carries a department for
  // departmental quote breakdown. Backfilled to PRO_SUPPLIES on existing
  // rows — note the historical-reporting caveat in the commit message.
  department      LineItemDepartment @default(PRO_SUPPLIES)
  // Phase 1 lifecycle spine: set at book time from `department`. Null
  // until the order transitions APPROVED → BOOKED.
  fulfillmentLane FulfillmentLane?    @map("fulfillment_lane")
  // Warehouse-lane only: PENDING_PICK at book time, advanced by the
  // Phase 2 picking workflow. Null on FLEET and STAGE lanes.
  pickStatus      LineItemPickStatus? @map("pick_status")
  description     String
  inventoryItemId String?            @map("inventory_item_id")
  assetCategoryId String?            @map("asset_category_id")
  startDate       DateTime?          @map("start_date") @db.Date
  endDate         DateTime?          @map("end_date") @db.Date
  rateType        RateType           @default(DAILY)
  rate            Decimal            @db.Decimal(10, 2)
  quantity        Int                @default(1)
  // Per-line pickup / return dates. Default to the parent Order's range,
  // but rep can override per line during quote review.
  pickupDate      DateTime           @map("pickup_date") @db.Date
  returnDate      DateTime           @map("return_date") @db.Date
  // Billable days — what the client is charged for. For cap-per-week
  // departments this typically differs from (returnDate - pickupDate)
  // because of the weekly cap; the rep can edit it freely. Stored in
  // the `days` column for backward compat.
  billableDays    Int                @default(1) @map("days")
  lineTotal       Decimal            @db.Decimal(12, 2)
  // Phase 2: AI-extracted client modifier preserved verbatim (e.g.
  // "no surveillance kits"). Displayed in italics in the builder; never
  // used to invent extra line items.
  qualifier       String?            @db.Text
  notes           String?            @db.Text
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  assetCategory AssetCategory? @relation(fields: [assetCategoryId], references: [id])
  // Phase 2 warehouse lane: zero-or-one PickListItem per OrderLineItem.
  // Only WAREHOUSE-lane lines get a PickListItem at book time. FLEET
  // and STAGE lines stay null.
  pickListItem  PickListItem?

  @@map("sr_order_line_items")
}

// First-class discounts on an order. Two scopes:
//   ORDER       — single grand-level discount; clamped to the
//                 department-discounted subtotal.
//   DEPARTMENT  — per LineItemDepartment; clamped to that
//                 department's line subtotal.
//
// App-layer uniqueness contract enforced in the API layer (not via
// @@unique here because the constraint is partial — one ORDER-scope
// row, and one row per departmentKey — Postgres doesn't model
// partial-unique-with-enum cleanly without an extension).
//
// Flat-total mode (UI affordance) computes an implied FIXED-value
// ORDER discount against the post-department subtotal and stores
// the result here — it's not a third type.
model OrderDiscount {
  id            String              @id @default(uuid())
  orderId       String              @map("order_id")

  scope         DiscountScope
  // Required when scope=DEPARTMENT, must be null when scope=ORDER.
  // Uses the LineItemDepartment enum directly so an invalid value
  // can't land via the API.
  departmentKey LineItemDepartment? @map("department_key")

  type          DiscountType
  // PERCENT: 0–100 (validated app-side). FIXED: dollar amount.
  // Stored at 2 decimals to match the rest of the money columns.
  value         Decimal             @db.Decimal(10, 2)

  // Surfaces on the PDF + UI row. Defaults to "Discount" so the
  // creator can ship without picking a label, but reps usually
  // type a reason (e.g. "Repeat-client courtesy").
  label         String              @default("Discount")

  createdById   String?             @map("created_by_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt      @map("updated_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User? @relation("OrderDiscountCreator", fields: [createdById], references: [id])

  @@index([orderId])
  @@index([orderId, scope, departmentKey])
  @@map("sr_order_discounts")
}

// ════════════════════════════════════════════════════════════════
// PHASE 2 — WAREHOUSE PICKING
// One PickList per Order with at least one WAREHOUSE-lane line item.
// Auto-created at book time in src/lib/orders/bookOrder.ts.
//
// Authoritative line-level status lives on OrderLineItem.pickStatus —
// Phase 3's LOADED_READY rollup scans order line items directly.
// PickListItem is the join row + per-line capture metadata (who
// scanned what, when). Keep this separation when adding fields.
//
// PARKING LOT (Phase 2.x): post-book line-item edits during ON_JOB
// don't currently sync into the PickList. If a new line item gets
// added to an order after the PickList is created, it won't appear
// in the picking floor view. Tracked as a known follow-up — see the
// TODO in bookOrder.ts and the line-item PATCH endpoints.
// ════════════════════════════════════════════════════════════════

enum PickListStatus {
  DRAFT            // created at book time; no picker assigned yet
  PICKING          // a warehouse user has started the pick session
  READY_TO_STAGE   // all items picked; awaiting move to staging area
  STAGED           // physically staged for loadout
  LOADED           // loaded onto outbound transport — warehouse lane terminal
  CANCELLED        // order cancelled or list voided
}

model PickList {
  id           String         @id @default(uuid())
  // One PickList per Order — enforced by @unique. Aggregating multiple
  // orders into a single "today's pulls" view is a Phase 2.1 parking-lot
  // item that would layer over this without changing the model.
  orderId      String         @unique @map("order_id")
  status       PickListStatus @default(DRAFT)
  // The picker who's actively working this list. Stamped on the
  // DRAFT → PICKING transition. Stays populated through subsequent
  // states for audit even after the session ends.
  assignedToId String?        @map("assigned_to_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  startedAt    DateTime?      @map("started_at")
  completedAt  DateTime?      @map("completed_at")

  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo User?          @relation("PickListAssignedTo", fields: [assignedToId], references: [id])
  items      PickListItem[]

  @@index([status])
  @@map("pick_lists")
}

model PickListItem {
  id              String    @id @default(uuid())
  pickListId      String    @map("pick_list_id")
  // Each OrderLineItem is in at most one PickList. The line's
  // authoritative pick state lives on OrderLineItem.pickStatus; this
  // row only carries the picker metadata.
  orderLineItemId String    @unique @map("order_line_item_id")
  // The code the picker scanned to mark this item PICKED. Typically
  // matches OrderLineItem.inventoryItem.code; null on manual-override
  // picks (items without a scannable SKU, or fallback path).
  scannedCode     String?   @map("scanned_code")
  pickedById      String?   @map("picked_by_id")
  pickedAt        DateTime? @map("picked_at")

  pickList      PickList      @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  orderLineItem OrderLineItem @relation(fields: [orderLineItemId], references: [id], onDelete: Cascade)
  pickedBy      User?         @relation("PickListItemPickedBy", fields: [pickedById], references: [id])

  @@index([pickListId])
  @@map("pick_list_items")
}

// Invoice — 1:many off Order (orderId NOT @unique). Phase 5 adds the
// `type` discriminator + PDF blob refs + line snapshot so a single
// order can carry both a primary RENTAL invoice (drives the order's
// close) and a satellite LD invoice (carries disputed high-dollar
// damage; non-blocking on the lifecycle). `Invoice.total` IS the third
// canonical money number (quote estimate → booked value → invoice
// total); never overwrite the Order.booked* snapshot from here.
model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  orderId       String        @map("order_id")
  // Phase 5: RENTAL (primary) drives the close; LD (satellite, Phase 5
  // commit 4) is non-blocking. Default RENTAL for forward-compat with
  // existing zero-row table. Enum is extensible.
  type          InvoiceType   @default(RENTAL)
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  // The final number. Sum of the lineSnapshot is guaranteed to equal
  // this — when the live order's line items differ from the booked
  // snapshot, the generator emits an ADJUSTMENT line so the math
  // balances and `total` always equals the booked total at issue.
  total         Decimal       @db.Decimal(12, 2)
  amountPaid    Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  balanceDue    Decimal       @default(0) @map("balance_due") @db.Decimal(12, 2)
  dueDate       DateTime?     @map("due_date") @db.Date
  sentAt        DateTime?     @map("sent_at")
  paidAt        DateTime?     @map("paid_at")
  notes         String?       @db.Text
  // PDF storage — mirrors the SignedAgreement / quote-pdf pattern.
  // pdfBlobKey is the Vercel Blob key (private bucket); pdfUrl is the
  // signed URL returned by put(); pdfGeneratedAt is the issuance
  // timestamp. Replace-on-regenerate: when an invoice's PDF is
  // re-rendered, the previous blob is deleted.
  pdfBlobKey       String?    @map("pdf_blob_key")
  pdfUrl           String?    @map("pdf_url")
  pdfGeneratedAt   DateTime?  @map("pdf_generated_at")
  // Structured line-item snapshot at issue time. Array of
  //   { description, category, qty, unitPrice, amount,
  //     kind: 'RENTAL_LINE' | 'ADJUSTMENT' | 'DAMAGE' }
  // Stays queryable for departmental revenue reporting (PostgreSQL
  // jsonb_path), and the shape is promotable to a relational
  // InvoiceLineItem model later without breaking callers.
  lineSnapshot     Json?      @map("line_snapshot")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  order       Order            @relation(fields: [orderId], references: [id])
  payments    Payment[]
  // Phase 5 commit 4 — DamageItems and InsuranceClaims tagged with
  // this invoice. For RENTAL: BILL_NOW damages billed here. For LD:
  // the damages that drove the LD invoice + any claims opened
  // against it.
  damageItems     DamageItem[]
  insuranceClaims InsuranceClaim[]
  emailDeliveries EmailDelivery[]

  @@index([orderId, type])
  @@map("sr_invoices")
}

enum InvoiceType {
  RENTAL
  LD
}

// Phase 5 commit 3 — native payment recording. PaymentLog (free-text,
// RW-shaped) stays for legacy RW invoices; new SirReel invoices use
// this typed model. Recording a Payment auto-updates the parent
// Invoice's amountPaid / balanceDue / status and (for a fully-paid
// RENTAL invoice) advances Order INVOICED → CLOSED. Voiding a
// Payment regresses those same fields. The booked snapshot is never
// written here.
enum PaymentMethod {
  CHECK
  WIRE
  ACH
  CREDIT_CARD
  CARDPOINTE
  CASH
  OTHER
}

// Phase 6 commit 1 — payment lifecycle. Pre-Phase-6 operator payments
// (CHECK/WIRE/CASH/OTHER) write CLEARED directly; card captures write
// CLEARED on successful auth+capture; ACH originations write PENDING,
// advance to SETTLED when CardPointe confirms file submission, and
// CLEARED when funds settle. RETURNED handles NSF / bank rejection;
// FAILED is the gateway-level decline path.
//
// LINCHPIN: reconcileInvoiceTotals counts only CLEARED non-voided
// payments. PENDING / SETTLED ACH must NOT mark an invoice paid or
// advance the order to CLOSED.
enum PaymentStatus {
  PENDING
  SETTLED
  CLEARED
  RETURNED
  FAILED
}

model Payment {
  id            String         @id @default(uuid())
  invoiceId     String         @map("invoice_id")
  // The amount applied to this invoice. Always > 0 — voids are tracked
  // via voidedAt, never by negative amounts (keeps SUM() math correct
  // when filtered to non-voided rows).
  amount        Decimal        @db.Decimal(12, 2)
  method        PaymentMethod
  // Phase 6 lifecycle. CLEARED is the only state that counts toward
  // invoice paid/balance. Default CLEARED for backward-compat with
  // existing operator-recorded payments (CHECK/WIRE/CASH/OTHER) which
  // are always "received" by the time they're entered.
  status        PaymentStatus  @default(CLEARED)
  // Operator-supplied reference: check #, wire confirmation, etc.
  // Free-text by design.
  reference     String?
  // Phase 6 — CardPointe transaction id (retref). Distinct from
  // `reference` so gateway txn ids stay queryable without polluting
  // the free-text column.
  gatewayRefId  String?        @map("gateway_ref_id")
  receivedAt    DateTime       @map("received_at")
  // Phase 6 ACH timestamps. Card captures stamp settledAt + clearedAt
  // = now() on the same write since auth+capture is instant; ACH
  // walks them out across the polling lifecycle.
  settledAt     DateTime?      @map("settled_at")
  clearedAt     DateTime?      @map("cleared_at")
  returnedAt    DateTime?      @map("returned_at")
  returnReason  String?        @map("return_reason") @db.Text
  // Phase 6 NACHA authorization — ACH-only; captured via SigCanvas
  // alongside the consent text shown to the payer at the moment of
  // authorization. Stored on the row so the auth artifact is co-
  // located with the payment it authorized.
  nachaAuthSignatureData String?   @map("nacha_auth_signature_data") @db.Text
  nachaAuthText          String?   @map("nacha_auth_text") @db.Text
  nachaAuthSignedAt      DateTime? @map("nacha_auth_signed_at")
  notes         String?        @db.Text
  // Phase 6 portal attribution. Operator-recorded payments set
  // recordedById; portal-initiated payments set
  // initiatedByPortalAccessId. Exactly one of the two must be set —
  // enforced at the application layer (Prisma can't express XOR via
  // schema alone; the recordPayment helper guards this).
  recordedById             String?    @map("recorded_by_id")
  initiatedByPortalAccessId String?   @map("initiated_by_portal_access_id")
  voidedAt      DateTime?      @map("voided_at")
  voidedById    String?        @map("voided_by_id")
  voidReason    String?        @map("void_reason") @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")

  invoice              Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy           User?         @relation("PaymentRecorder", fields: [recordedById], references: [id])
  voidedBy             User?         @relation("PaymentVoider", fields: [voidedById], references: [id])
  initiatedByPortalAccess PortalAccess? @relation("PortalInitiatedPayments", fields: [initiatedByPortalAccessId], references: [id])

  @@index([invoiceId])
  @@index([receivedAt])
  @@index([invoiceId, voidedAt])
  // Phase 6 — polling job pulls PENDING/SETTLED ACH rows; status index
  // keeps that scan tight as payment volume grows.
  @@index([status])
  @@index([initiatedByPortalAccessId])
  @@map("sr_payments")
}

