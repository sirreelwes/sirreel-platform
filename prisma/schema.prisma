// ============================================================
// SALES PIPELINE INQUIRIES
// Phase 1 manual entry; Gmail auto-parse populates the same model
// in Phase 3. `convertedJobId` tracks NEW → CONVERTED transitions
// where an Inquiry becomes a Job via /orders/new-quote.
// ============================================================

enum InquirySource {
  MANUAL
  GMAIL
  WEB_FORM
}

enum InquiryStatus {
  NEW
  CONVERTED
  DISMISSED
}

model Inquiry {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  source             InquirySource @default(MANUAL)
  status             InquiryStatus @default(NEW)

  title              String
  description        String        @db.Text

  companyId          String?       @map("company_id")
  company            Company?      @relation(fields: [companyId], references: [id])
  personId           String?       @map("person_id")
  person             Person?       @relation("InquiryContact", fields: [personId], references: [id])

  estimatedValue     Decimal?      @map("estimated_value") @db.Decimal(12, 2)
  preferredStartDate DateTime?     @map("preferred_start_date") @db.Date
  preferredEndDate   DateTime?     @map("preferred_end_date") @db.Date

  assignedToId       String?       @map("assigned_to_id")
  assignedTo         User?         @relation("InquiryAssignedTo", fields: [assignedToId], references: [id])

  convertedJobId     String?       @unique @map("converted_job_id")
  convertedJob       Job?          @relation("ConvertedFromInquiry", fields: [convertedJobId], references: [id])

  // Phase 1b add-on triage — set when the inquiry was converted by
  // attaching to an EXISTING Job (a new Order on that job, marked
  // with Order.addedToJobAt). Disjoint with convertedJobId in
  // practice: the new-Job path sets convertedJobId, the add-on path
  // sets convertedOrderId. @unique mirrors convertedJobId so each
  // Order can satisfy at most one inquiry.
  convertedOrderId   String?       @unique @map("converted_order_id")
  convertedOrder     Order?        @relation("ConvertedFromInquiryToOrder", fields: [convertedOrderId], references: [id])

  sourceMetadata     Json?         @map("source_metadata")

  // RFC822 Message-Id of the originating email when source=GMAIL.
  // Used to dedupe cross-inbox copies of the same message (each Gmail
  // inbox has its own EmailMessage row with a distinct id, but they
  // share rfc822MessageId). The partial unique index `sr_inquiries_rfc822_gmail_uniq`
  // (added via raw SQL — Prisma can't express filtered uniques) makes
  // a concurrent double-capture impossible at the DB layer.
  rfc822MessageId    String?       @map("rfc822_message_id")

  @@index([status, createdAt])
  @@index([assignedToId])
  @@index([rfc822MessageId])
  @@map("sr_inquiries")
}

