  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  job             Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  uploadedBy      User     @relation("CoiCheckUploader", fields: [uploadedById], references: [id])
  humanDecisionBy User?    @relation("CoiCheckDecider", fields: [humanDecisionById], references: [id])
  // Phase 5 commit 4 — claims that reference this COI as the policy
  // they were filed against.
  insuranceClaims InsuranceClaim[]

  @@index([jobId])
  @@index([companyId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([humanDecision])
  @@index([policyExpiryDate])
  @@map("sr_coi_checks")
}

// ============================================================
// CLIENT RELATIONSHIP HUB (CRH) — May 2026
// Cadence engine, portal access, company-level paperwork, and AI
// reply classification. See docs/specs/client-relationship-hub-brief.md
// for the full spec.
// ============================================================

enum CadenceState {
  QUOTE_DRAFT
  QUOTE_SENT
  QUOTE_ACKNOWLEDGED
  QUOTE_DISCUSSING
  BOOKED
  PICKUP_CONFIRMED
  IN_PROGRESS
  RETURNED
  INVOICED
  PAID
  WRAPPED
  LOST
  CANCELLED
}

enum LostReason {
  NO_RESPONSE
  ACKNOWLEDGED_NO_BOOK
  EXPLICIT_REJECTION
  MANUAL_CLOSE
}

enum ReplyClassification {
  PURE_ACKNOWLEDGMENT
  ACTIVE_DISCUSSION
  BOOKING_SIGNAL
  EXPLICIT_REJECTION
  UNCLEAR
}

enum InferredFormType {
  BOOKING_INQUIRY
  ANNUAL_AGREEMENT
  JOB_AGREEMENT
  DAMAGE_REPORT
  COI
}

enum CadenceEventType {
  // Unbooked cadence
  QUOTE_NUDGE_24H
  QUOTE_CHECKIN_T72
  QUOTE_CLOSEDOWN_T24
  QUOTE_LOST_MARK

  // Acknowledged-state cadence
  ACK_QUESTIONS_PROMPT_24H
  ACK_SWEETEN_T72
  ACK_CLOSEDOWN_T24

  // Booked cadence
  BOOKING_WELCOME
  COI_RECEIVED_ACK
  PRE_PICKUP_DETAILS_T48
  FINAL_CONFIRM_T24
  PICKUP_DAY_AM
  MID_RENTAL_CHECKIN
  RETURN_REMINDER_T24
  RETURN_ACKNOWLEDGMENT
  WRAP_THANKS_T24
  INVOICE_DELIVERY
  PAYMENT_REMINDER_T14
  REPEAT_BUSINESS_T30
  // Phase 3 lifecycle: emitted by the LOADED_READY rollup when both
  // warehouse + fleet lanes hit terminal. One of the two required
  // client notifications per the lifecycle spec (Phase 0 addendum);
  // the other (CHECKOUT_SIGN_OFF) lands with the future fleet
  // checkout flow.
  LOADED_AND_READY

  // Re-engagement
  LOST_REENGAGEMENT_2W
  LOST_SOFT_CHECKIN_90D

  // Annual paperwork
  ANNUAL_EXPIRY_60D
  ANNUAL_EXPIRY_30D
  ANNUAL_EXPIRY_7D

  // Portal lifecycle
  PORTAL_SUNSET_REMINDER_23M
}

/// Tracks every automated and manual touchpoint for reporting and debugging.
/// Created by state-transition hooks; consumed by /api/cron/cadence which
/// fires due events (scheduledFor <= now AND executedAt IS NULL).
model CadenceEvent {
  id           String           @id @default(uuid())
  orderId      String           @map("order_id")
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType    CadenceEventType @map("event_type")
  scheduledFor DateTime         @map("scheduled_for")
  executedAt   DateTime?        @map("executed_at")
  skipped      Boolean          @default(false)
  skipReason   String?          @map("skip_reason")
  // Pointer to the EmailMessage row that resulted from this event (when the
  // event was an email send). Kept as a free String rather than a relation so
  // the email row can be hard-deleted without cascading into cadence history.
  emailId      String?          @map("email_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@index([orderId])
  @@index([scheduledFor, executedAt])
  @@map("sr_cadence_events")
}

/// Per-contact portal access record. `contactId` references Person — there is
/// no separate Contact model in this schema; the CRH brief's `Contact` maps
/// 1:1 to `Person` for SirReel.
/// Person-scoped passwordless portal session. Distinct from
/// PortalAccess (which is order-scoped, requires non-null orderId) and
/// from ClientSession (loose email-string key, no FK).
///
/// Lifecycle:
///   1. POST /api/portal/auth/request → INSERT row with magicLinkToken
///      + expiry. Email sent to the matching Person (response is
///      neutral whether or not the email matched — no enumeration).
///   2. GET /api/portal/auth/verify?token=X → look up by token, check
///      magicLinkExpiresAt + magicLinkUsedAt + revokedAt. Stamp
///      magicLinkUsedAt and issue an HMAC-signed cookie carrying this
///      row's id (mirror of jobSession.ts).
///   3. Subsequent /portal/... requests → cookie HMAC-verified, then
///      this row is loaded; revokedAt is the kill switch.
///
/// Cookie exp (30 days) is in jobSession.ts territory; row revocation
/// is via revokedAt.
model PersonSession {
  id        String   @id @default(uuid())
  personId  String   @map("person_id")
  person    Person   @relation(fields: [personId], references: [id])

  // Magic-link state — populated on request, consumed on verify.
  magicLinkToken     String    @unique @map("magic_link_token")
  magicLinkExpiresAt DateTime  @map("magic_link_expires_at")
  magicLinkUsedAt    DateTime? @map("magic_link_used_at")

  // Audit
  ipAddress      String?   @map("ip_address")
  userAgent      String?   @map("user_agent") @db.Text
  lastAccessedAt DateTime? @map("last_accessed_at")
  accessCount    Int       @default(0) @map("access_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")

  @@index([personId])
  @@map("person_sessions")
}

model PortalAccess {
  id                 String    @id @default(uuid())
  orderId            String    @map("order_id")
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  contactId          String    @map("contact_id")
  contact            Person    @relation("PortalAccessContact", fields: [contactId], references: [id])
  magicLinkToken     String    @unique @map("magic_link_token")
  magicLinkExpiresAt DateTime  @map("magic_link_expires_at")
  // Optional password (hashed, never plain) for persistent login after magic
  // link expires. Bcrypt/argon2 — see CRH brief §13 portal security.
  passwordHash       String?   @map("password_hash")
  createdAt          DateTime  @default(now()) @map("created_at")
  revokedAt          DateTime? @map("revoked_at")
  revokedBy          String?   @map("revoked_by")
  lastAccessedAt    DateTime?  @map("last_accessed_at")
  accessCount        Int       @default(0) @map("access_count")

  // Phase 6 commit 1 — back-relation for portal-initiated payments
  // (card or ACH). Recorded operator payments use Payment.recordedBy
  // instead.
  initiatedPayments Payment[] @relation("PortalInitiatedPayments")

  @@index([orderId])
  @@index([contactId])
  @@index([magicLinkToken])
  @@map("sr_portal_accesses")
}

/// One row per hourly health-check run. `services` holds the full per-service
/// JSON payload returned by /api/admin/health so the /admin/health page can
/// render a 24h history without re-probing. `alertedAt` is set when the cron
/// posted to Slack for this run — used by the 4h alert-suppression window so
/// a sustained outage doesn't spam the channel.
model HealthCheckLog {
  id          String    @id @default(uuid())
  checkedAt   DateTime  @default(now()) @map("checked_at")
  overall     String    // "healthy" | "degraded" | "down"
  services    Json      // full per-service detail (see HealthReport type)
  alertedAt   DateTime? @map("alerted_at")
  alertDetail String?   @map("alert_detail")

  @@index([checkedAt(sort: Desc)])
  @@index([overall, checkedAt])
  @@map("sr_health_check_logs")
}

/// Per-day counter for the date-based order/quote number format
/// (`S{YYMMDD}-{NNN}`). One row per Pacific-time calendar date; `seq`
/// is incremented atomically by `nextOrderNumber()` via UPSERT inside
/// the same transaction as the Order insert, so a rolled-back order
/// rolls back its number too (no daily gaps unless the day itself
/// rolls over mid-tx — acceptable). The legacy `sr_order_number_seq`
/// Postgres SEQUENCE is retained but unused — the 11 pre-existing
/// SR-ORD-* orders keep their numbers (forward-only switch).
model OrderDailyCounter {
  dateKey String @id @map("date_key") // YYMMDD in America/Los_Angeles
  seq     Int    @default(0)

  @@map("order_daily_counter")
}

/// Per-send delivery audit — one row per outbound Resend dispatch.
/// Capture: written at send time with `resendMessageId` (the unique
/// id Resend returns from emails.send()) and `status=SENT`.
/// Webhook: POST /api/webhooks/resend looks up by resendMessageId
/// (unique) and updates `status` + `statusDetail` + `statusAt` as
/// Resend's events arrive (delivered / delivery_delayed / bounced /
/// complained).
/// Surface: order detail page joins on `orderId` to render a
/// delivery pill next to each cadence/email row.
/// Parent FKs are all optional + SetNull on delete so the delivery
/// audit row survives even if the order/invoice is hard-deleted.
model EmailDelivery {
  id              String              @id @default(uuid())
  resendMessageId String              @unique @map("resend_message_id")
  status          EmailDeliveryStatus @default(SENT)
  statusDetail    String?             @map("status_detail")
  statusAt        DateTime            @default(now()) @map("status_at")

  // Send context — at least one of these is set by the caller. Used
  // by the order detail UI to scope the deliveries shown.
  orderId         String?  @map("order_id")
  invoiceId       String?  @map("invoice_id")
  quoteFollowUpId String?  @map("quote_follow_up_id")

  // Envelope — recorded at send for display + debugging
  toAddress       String   @map("to_address")
  ccAddresses     String[] @map("cc_addresses")
  subject         String
  // sendAgreementEmail's `label` — e.g. "send-quote:SR-ORD-0042"
  label           String?

  sentAt    DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt        @map("updated_at")

  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  invoice Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  quoteFollowUp QuoteFollowUp? @relation(fields: [quoteFollowUpId], references: [id], onDelete: SetNull)

  @@index([orderId, sentAt(sort: Desc)])
  @@index([invoiceId])
  @@index([status])
  @@map("sr_email_deliveries")
}

enum EmailDeliveryStatus {
  SENT
  DELIVERED
  DELAYED
  BOUNCED
  COMPLAINED
}

// ════════════════════════════════════════════════════════════════
// PHASE — HR (isolated)
// ════════════════════════════════════════════════════════════════
//
// HR data is the most sensitive in the system (medical, leave,
// discipline, payroll). The architecture mirrors the claims mail
// pipeline (inbox mode → authorship gate → parse → disposition →
// triage UI) with one structural difference: HR mail is STORED IN
// SEPARATE TABLES (HrEmail, HrMail, HrAttachment) and NEVER written
// to EmailMessage / EmailThread / ClaimMail. The 12+ existing email-
// read surfaces (sales suggested-inquiries, claims triage, exec
// coverage, inbox view, AI extraction cron, etc.) all query
// EmailMessage — so by design they cannot return HR rows. Adding a
// new email-read feature does not need to remember to "exclude HR";
// the table partition makes leakage structurally impossible rather
// than procedurally avoidable.
//
// Access is double-gated: every HR API route AND the nav entry call
// requireHrAccess() (src/lib/hr/allowlist.ts), which checks a
// hardcoded constant + HR_ALLOWLIST env override. A DB-managed flag
// was rejected here because a UI bug or schema migration that wrote
// the wrong row could escalate privilege; the code-reviewed constant
// can only change via a deploy.

// Employee — payroll/HR identity. Distinct from User (which is the
// access-control / login identity). 1:0..1 link from Employee to
// User: most current staff have an HQ login and the link is
// populated; non-login staff (future drivers / warehouse) can exist
// as Employees without a User row.
//
// Email-match fields: workEmail is the canonical address; personalEmails
// captures the secondary addresses HR mail might actually come from
// (Gmail personal accounts, payroll-provider addresses, etc.). The
// Sonnet employee-match step in onboardFromHrEmail searches both.
model Employee {
  id              String   @id @default(uuid())
  fullName        String
  workEmail       String?  @unique @map("work_email")
  personalEmails  String[] @map("personal_emails")
  title           String?
  department      String?
  isActive        Boolean  @default(true) @map("is_active")
  startedOn       DateTime? @map("started_on") @db.Date
  leftOn          DateTime? @map("left_on")    @db.Date
  notes           String?  @db.Text

  // Nullable link to the HQ login. UNIQUE so the inverse on User
  // is a clean 1:1; reverse is User.employee.
  userId          String?  @unique @map("user_id")
  user            User?    @relation("EmployeeUserLink", fields: [userId], references: [id], onDelete: SetNull)

  hrMail          HrMail[]
  hrAttachments   HrAttachment[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  @@map("hr_employees")
}

// HrEmail — parallel to EmailMessage; ISOLATED. Pubsub branches at
// the source (`if email === hr@sirreel.com`) and writes here instead
// of EmailMessage. This row is the single source-of-truth for an
// inbound HR Gmail message; the HrMail disposition + HrAttachment
// children point back to it.
model HrEmail {
  id              String   @id @default(uuid())
  // Same dedup contract EmailMessage has — Gmail's per-inbox id is
  // unique within an inbox; the RFC-2822 Message-Id is the cross-
  // inbox key (used for the staff-forward-into-hr@ idempotency check).
  gmailMessageId  String   @unique @map("gmail_message_id")
  rfc822MessageId String?  @map("rfc822_message_id")
  inReplyTo       String?  @map("in_reply_to")

  fromAddress     String   @map("from_address")
  toAddresses     String[] @map("to_addresses")
  subject         String
  snippet         String?  @db.Text
  bodyText        String?  @map("body_text") @db.Text
  bodyHtml        String?  @map("body_html") @db.Text
  bodySource      String?  @map("body_source")
  attachmentCount Int      @default(0) @map("attachment_count")
  routingHeaders  Json?    @map("routing_headers")

  sentAt          DateTime @map("sent_at")
  isRead          Boolean  @default(false) @map("is_read")

  // 0-or-1 — populated by onboardFromHrEmail. Null when the
  // background helper hasn't run yet (rare; fire-and-forget); the UI
  // treats missing disposition as "still being processed".
  hrMail          HrMail?
  attachments     HrAttachment[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  @@index([rfc822MessageId])
  @@index([sentAt(sort: Desc)])
  @@map("hr_emails")
}

enum HrCategory {
  TIMESHEET
  PTO_LEAVE
  MEDICAL
  PAYROLL
  BENEFITS
  DISCIPLINE
  COMPLAINT
  ONBOARDING
  RESIGNATION
  OTHER
}

enum HrDisposition {
  FILED         // confident employee match + category assigned
  NEEDS_REVIEW  // partial info — Wes/Dani assign manually
  IGNORED       // non-HR noise (auto-replies, newsletters that slipped through)
}

// HrMail — disposition + parse snapshot per HrEmail. Mirror of
// ClaimMail's role on the claims side. employeeId is nullable for
// NEEDS_REVIEW + IGNORED rows; the triage UI lets Wes/Dani assign it.
model HrMail {
  id              String        @id @default(uuid())
  hrEmailId       String        @unique @map("hr_email_id")
  employeeId      String?       @map("employee_id")

  category        HrCategory
  disposition    HrDisposition
  // Sonnet parse output: { employeeNameGuess, category, summary,
  // confidence, reasoning }. JSON keeps the surface flexible while
  // the classifier prompt evolves; the triage UI reads named keys.
  parse           Json?
  reason          String?

  dismissed       Boolean       @default(false)
  reviewedById    String?       @map("reviewed_by_id")
  reviewedAt      DateTime?     @map("reviewed_at")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt      @map("updated_at")

  hrEmail         HrEmail       @relation(fields: [hrEmailId], references: [id], onDelete: Cascade)
  employee        Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  reviewedBy      User?         @relation("HrMailReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([disposition, dismissed])
  @@map("hr_mail")
}

// HrAttachment — file metadata + Vercel Blob URL. Parallel to
// ClaimDocument with HR-specific category set. employeeId is set
// when the parent HrEmail's HrMail row links to an employee;
// orphaned attachments (NEEDS_REVIEW / IGNORED) keep employeeId null
// until the rep assigns the parent row.
model HrAttachment {
  id              String      @id @default(uuid())
  hrEmailId       String?     @map("hr_email_id")
  employeeId      String?     @map("employee_id")

  category        HrCategory  @default(OTHER)
  title           String
  fileUrl         String      @map("file_url")
  mimeType        String?     @map("mime_type")
  sizeBytes       Int?        @map("size_bytes")
  notes           String?     @db.Text

  // AI classifier provenance — same idea as ClaimDocument.typeSource
  // (EMAIL_INGEST vs AI_SUGGESTED vs USER). Reuses the existing
  // DocTypeSource enum since the semantics are identical.
  typeSource      DocTypeSource? @map("type_source")
  typeConfidence  Float?         @map("type_confidence")

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt      @map("updated_at")

  hrEmail         HrEmail?    @relation(fields: [hrEmailId], references: [id], onDelete: Cascade)
  employee        Employee?   @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([hrEmailId])
  @@map("hr_attachments")
}

// ═══════════════════════════════════════════════════════════════
// PHASE INCIDENTS — hub between claim-mail, claims, and L&D billing
// ═══════════════════════════════════════════════════════════════
//
// Strategic frame: an incident's recovery paths in preference order
// are CARRIER CLAIM → BILL RENTER → ABSORB. The carrier-required
// floor that used to gate auto-drafted claims now lives on the
// "Upgrade to claim" action against an Incident, where it belongs.
//
// One incident can produce multiple claims (multi-carrier, joint
// renter+driver claims). Status reflects current posture, not a
// terminal — an incident can move through several (e.g.
// OPEN → CLAIM_FILED → BILLED_RENTER as the carrier pays a portion
// and we bill the renter for the deductible delta).
//
// Connections in this build are ADDITIVE — every existing
// InsuranceClaim / DamageItem / ClaimMail / ClaimDocument row keeps
// its prior shape; the new incidentId FKs are nullable and forward-
// only.

enum IncidentSource {
  EMAIL              // claim-mail "Open incident report"
  RETURN_INSPECTION  // captured during the L&D return-check (future
                     //   bridge; not auto-created in this phase)
  MANUAL             // dispatcher / rep clicks "+ New incident"
}

enum IncidentStatus {
  OPEN
  CLAIM_FILED        // ≥1 InsuranceClaim with incidentId set
  BILLED_RENTER      // ≥1 DamageItem with incidentId set + BILL_NOW
  RESOLVED           // carrier + renter recovery complete
  WRITTEN_OFF        // explicitly absorbed
}

model Incident {
  id             String         @id @default(uuid())
  // SR-INC-NNNN. Generated by nextIncidentNumber() via the
  // sr_incident_number_seq Postgres sequence (created in a follow-up
  // raw SQL after db push, same pattern as sr_claim_number_seq).
  incidentNumber String         @unique @map("incident_number")
  source         IncidentSource
  status         IncidentStatus @default(OPEN)

  // The Order / Asset / Company connection. All nullable so the
  // earliest possible Incident (an email arrives without enough info
  // to match an Order yet) still creates cleanly. The triage UI nags
  // when an Incident has been OPEN > N hours without an Order link.
  orderId   String? @map("order_id")
  assetId   String? @map("asset_id")
  companyId String? @map("company_id")

  description String    @db.Text
  // When the underlying loss occurred (if known). Distinct from
  // createdAt which is when the row landed in HQ. Carrier claims
  // require this; the upgrade-to-claim form forces it then.
  occurredAt  DateTime? @map("occurred_at") @db.Date

  createdById String? @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("IncidentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  claims      InsuranceClaim[]
  claimMail   ClaimMail[]
  documents   ClaimDocument[]
  damageItems DamageItem[]

  @@index([status])
  @@index([orderId])
  @@index([createdAt(sort: Desc)])
  @@map("sr_incidents")
}
