// Full lifecycle status — canonical state machine per order-lifecycle-spec
// (Phase 1: Book-it spine). Old CONFIRMED/ACTIVE renamed in-place to
// APPROVED/ON_JOB via `ALTER TYPE … RENAME VALUE` (preserves rows). New
// states added additively. Forward flow:
//   DRAFT → QUOTE_SENT → APPROVED → BOOKED → LOADED_READY → ON_JOB
//        → RETURNED → LD_CHECK → INVOICED → CLOSED
// CANCELLED is the off-ramp; LOADED_READY is rolled up from parallel
// fleet + warehouse lanes (Phase 3, not yet wired).
enum OrderStatus {
  DRAFT
  QUOTE_SENT
  APPROVED
  BOOKED
  LOADED_READY
  ON_JOB
  RETURNED
  LD_CHECK
  INVOICED
  CLOSED
  CANCELLED
}

// Parallel sales-stage status — added in Phase 1 of the sales pipeline rework.
// `OrderStatus` (above) remains the authoritative full-lifecycle field used by
// /orders, /dispatch, and downstream operations. `OrderQuoteStatus` is the
// sales-pipeline view of the same Order, kept in sync via deriveQuoteStatus()
// in src/lib/orders/quoteStatus.ts whenever Order.status mutates.
enum OrderQuoteStatus {
  DRAFT
  SENT
  WON
  LOST
  EXPIRED
}

enum LineItemType {
  VEHICLE
  EQUIPMENT
  EXPENDABLE
  LABOR
  FEE
  DISCOUNT
}

enum LineItemDepartment {
  VEHICLES
  COMMUNICATIONS
  STAGES
  PRO_SUPPLIES
  EXPENDABLES
  GE
  ART
}

// First-class order discounts (additive Phase). Coexists with legacy
// type='DISCOUNT' OrderLineItem rows — those stay as-is for existing
// orders, but all NEW discount entry funnels through this model so the
// two surfaces can't ship divergent rendering / clamping rules. The
// shared discount-aware totals util treats legacy DISCOUNT lines as
// part of the line subtotal (their negative lineTotal already reduces
// it) and applies these structured discounts ON TOP.
//
// Booked invoices are NOT retro-modified by new discounts — the
// existing bookedSubtotal/bookedTotal snapshot stays canonical for
// already-issued RENTAL invoices; the discount surfaces as an
// ADJUSTMENT line on next regen instead.
enum DiscountScope {
  ORDER
  DEPARTMENT
}

enum DiscountType {
  PERCENT
  FIXED
}

// Phase 1 lifecycle / book-time line routing. Set on each OrderLineItem
// atomically inside POST /api/orders/[id]/book based on the line's
// department:
//   VEHICLES                → FLEET     (no pickStatus; fleet team
//                                         assigns specific assets via
//                                         the existing /scheduling/
//                                         booking-items/[id]/assign path)
//   STAGES                  → STAGE     (no pickStatus; stage logistics
//                                         live on StageBookingTerms)
//   COMMUNICATIONS,
//   PRO_SUPPLIES,
//   EXPENDABLES, GE, ART    → WAREHOUSE (pickStatus = PENDING_PICK;
//                                         consumed by Phase 2 PickList
//                                         and picking workflow)
enum FulfillmentLane {
  FLEET
  WAREHOUSE
  STAGE
}

// Warehouse-lane progression for a single OrderLineItem. Nullable on
// non-warehouse lines. The PickList model + picking UX (Phase 2) reads
// this to drive the pick floor; LOADED feeds the rollup that fires
// LOADED_READY on the order (Phase 3).
enum LineItemPickStatus {
  PENDING_PICK
  PICKED
  STAGED
  LOADED
}

enum RateType {
  DAILY
  WEEKLY
  MONTHLY
  FLAT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  VOID
}

