  bookingAssignment BookingAssignment? @relation("AssignmentInspections", fields: [bookingAssignmentId], references: [id])
  inspectedByUser   User               @relation("InspectedBy", fields: [inspectedBy], references: [id])
  damageItems       DamageItem[]

  // Used in claims
  checkoutClaims InsuranceClaim[] @relation("CheckoutInspection")
  returnClaims   InsuranceClaim[] @relation("ReturnInspection")

  @@map("inspections")
}

enum DamageType {
  SCRATCH
  DENT
  CRACK
  MISSING_PART
  MECHANICAL
  INTERIOR
  OTHER
}

enum DamageSeverity {
  MINOR
  MODERATE
  MAJOR
}

// Phase 5 commit 4 — return-disposition triage decision per damage
// item. PENDING is the just-captured default. BILL_NOW goes onto the
// next-generated RENTAL invoice as a DAMAGE line. SEND_TO_LD is
// collected by the LD invoice generator. WAIVED is operator's
// "goodwill / pre-existing / not billable" call.
enum DamageDisposition {
  PENDING
  BILL_NOW
  SEND_TO_LD
  WAIVED
}

model DamageItem {
  id                  String         @id @default(uuid())
  inspectionId        String         @map("inspection_id")
  locationOnVehicle   String         @map("location_on_vehicle") // "driver side rear panel"
  damageType          DamageType     @map("damage_type")
  severity            DamageSeverity
  photoUrl            String?        @map("photo_url")
  estimatedRepairCost Decimal?       @map("estimated_repair_cost") @db.Decimal(10, 2)
  isPreExisting       Boolean        @default(false) @map("is_pre_existing")
  notes               String?        @db.Text

  // Phase 5 commit 4 — triage decision + which invoice it landed on.
  disposition DamageDisposition @default(PENDING)
  // Set when the damage gets included in an Invoice's lineSnapshot.
  // For BILL_NOW: the rental invoice that generated next. For
  // SEND_TO_LD: the LD invoice that opened the claim.
  invoiceId   String?           @map("invoice_id")

  // Link to claim
  claimId String? @map("claim_id")
  // Phase Incidents — damage rows now know about their parent Incident
  // when one exists. The "Bill renter" action on an Incident routes
  // here. Nullable to keep existing damage rows (created via inspection
  // capture, not yet through the Incident hub) untouched.
  incidentId String? @map("incident_id")

  // Relations
  inspection Inspection      @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  claim      InsuranceClaim? @relation(fields: [claimId], references: [id])
  invoice    Invoice?        @relation(fields: [invoiceId], references: [id])
  incident   Incident?       @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([disposition])
  @@index([invoiceId])
  @@index([incidentId])
  @@map("damage_items")
}

// ═══════════════════════════════════════
// 9. INSURANCE CLAIMS
// ═══════════════════════════════════════

enum ClaimStatus {
  DRAFT
  READY_TO_SEND
  SUBMITTED
  ACKNOWLEDGED
  NEGOTIATING
  SETTLED
  DENIED
  ESCALATED
  CLOSED
}

model InsuranceClaim {
  id                   String      @id @default(uuid())
  // Phase 5 commit 4: new claims use SR-CLM-NNNN (sr_claim_number_seq).
  // Legacy SRC-2026-NNNN-style numbers are accepted for any rows the
  // RentalWorks-era data migration may bring in later.
  claimNumber          String      @unique @map("claim_number")
  // Phase A onboarding — bookingId/assetId became nullable so
  // historical in-flight claims (created before the asset/booking
  // tracking existed in HQ, or for total-loss/theft cases where
  // a clean inspection pair doesn't exist) can be onboarded. The
  // openLdClaim() helper still requires + sets both from the LD
  // invoice graph; null is only for the POST /api/claims manual
  // onboarding path. companyId stays required — every claim is
  // filed against a renter.
  bookingId            String?     @map("booking_id")
  assetId              String?     @map("asset_id")
  companyId            String      @map("company_id")
  // Phase 5 commit 4 — high-dollar disputes (theft / total loss /
  // major mechanical) may lack a clean inspection pair, and a hard
  // NOT NULL would block exactly the claims this phase handles. The
  // LD disposition still creates a RETURN Inspection by default
  // when a return occurs — these are null only for genuine no-return
  // cases.
  checkoutInspectionId String?     @map("checkout_inspection_id")
  returnInspectionId   String?     @map("return_inspection_id")
  // Phase 5 commit 4 — links to the LD invoice + COI on file. The
  // ClaimDocument linker still covers arbitrary supporting docs; these
  // FKs are the direct canonical pointers used by the order-detail
  // pipeline surface.
  invoiceId            String?     @map("invoice_id")
  coiCheckId           String?     @map("coi_check_id")
  status               ClaimStatus @default(DRAFT)

  // Insurance details
  filedAgainst  String  @map("filed_against") // Insurance company name
  adjusterName  String? @map("adjuster_name")
  adjusterPhone String? @map("adjuster_phone")
  adjusterEmail String? @map("adjuster_email")
  policyNumber  String? @map("policy_number")
  // The carrier's own claim number (e.g. Intact "0AB459860"), distinct
  // from our SR-CLM-NNNN and from the renter's policyNumber. Captured
  // so reps can quote either side's reference in correspondence and
  // so the future email scanner has a deterministic join key to
  // auto-attach inbound adjuster mail to the right claim record.
  carrierClaimNumber String? @map("carrier_claim_number")

  // Incident
  incidentDate        DateTime @map("incident_date") @db.Date
  incidentDescription String   @map("incident_description") @db.Text

  // Costs
  repairEstimate   Decimal? @map("repair_estimate") @db.Decimal(10, 2)
  repairActual     Decimal? @map("repair_actual") @db.Decimal(10, 2)
  repairVendor     String?  @map("repair_vendor")
  daysOutOfService Int?     @map("days_out_of_service")
  dailyRevenueRate Decimal? @map("daily_revenue_rate") @db.Decimal(10, 2)
  lossOfRevenue    Decimal? @map("loss_of_revenue") @db.Decimal(10, 2)
  totalDemand      Decimal? @map("total_demand") @db.Decimal(10, 2)
  amountOffered    Decimal? @map("amount_offered") @db.Decimal(10, 2)
  // amountSettled is GROSS — the dollar figure the carrier honored
  // before the renter's deductible is netted out. Client-exposure
  // math (LD balanceDue − (amountSettled − deductibleAmount)) does
  // the subtraction at compute time. Don't pre-net at write or the
  // deductible will be double-counted.
  amountSettled    Decimal? @map("amount_settled") @db.Decimal(10, 2)

  // Phase A ledger fields — replace the prior "everything goes in
  // notes" workflow with structured columns so the contract-vs-
  // insurance ledger + client-exposure math can be computed
  // server-side and rendered consistently.
  //
  //   lossAmount         — replacement-cost value of the loss (the
  //                        Clause-14 anchor we'd argue from at trial)
  //   acvReceived        — carrier's depreciated valuation (pre-
  //                        negotiation), captured for adjuster-
  //                        strategy + "how much did they shave off"
  //                        rollups
  //   depreciationApplied — explicit dollar value the carrier removed
  //                        from lossAmount to arrive at ACV. Stored
  //                        separately so the rollup doesn't need to
  //                        infer it
  //   deductibleAmount    — renter's deductible per Clause 9. Drives
  //                        the (amountSettled − deductibleAmount)
  //                        net-to-us value in client-exposure math
  //   adminFeeAmount      — the 10% admin fee per the Missing
  //                        Equipment Return Policy. Today hand-rolled
  //                        into LD invoice line items by Ana —
  //                        storing it on the claim makes the
  //                        client-exposure picture explicit
  lossAmount           Decimal? @map("loss_amount")            @db.Decimal(10, 2)
  // Contract-side billed amount captured DIRECTLY on the claim. When
  // an LD invoice gets linked later, Invoice.total takes precedence
  // for the ledger view. During historical onboarding the LD invoice
  // typically doesn't exist yet, so this field carries the
  // "what we billed the client" figure so the contract-vs-insurance
  // ledger composition has a contract side to net against.
  contractAmount       Decimal? @map("contract_amount")         @db.Decimal(10, 2)
  acvReceived          Decimal? @map("acv_received")           @db.Decimal(10, 2)
  depreciationApplied  Decimal? @map("depreciation_applied")   @db.Decimal(10, 2)
  deductibleAmount     Decimal? @map("deductible_amount")      @db.Decimal(10, 2)
  adminFeeAmount       Decimal? @map("admin_fee_amount")       @db.Decimal(10, 2)

  // Phase A follow-up cadence — drives the OVERDUE_RESPONSE /
  // GONE_QUIET badges. assignedTo (already on the model) is the
  // owner; these two columns are when-it's-on-them and when-they-
  // last-heard-anything.
  nextActionAt         DateTime? @map("next_action_at")
  lastContactAt        DateTime? @map("last_contact_at")

  // AI
  demandLetterUrl   String? @map("demand_letter_url")
  aiGeneratedLetter String? @map("ai_generated_letter") @db.Text
  aiCounterResponse String? @map("ai_counter_response") @db.Text

  assignedTo String? @map("assigned_to")
  notes      String? @db.Text

  // Set when the claims@ → onboarding handler created this DRAFT claim
  // from an inbound forwarded email. Two purposes:
  //   1. Drives the "From email — review" badge on /claims so Ana can
  //      sign off before the draft becomes a real claim.
  //   2. Click-through to the source EmailMessage from the claim detail
  //      page (the rep should be able to see the original chain that
  //      drafted the claim).
  // Null for everything onboarded via the manual paste flow or the
  // openLdClaim() LD-invoice path.
  onboardedFromEmailMessageId String?    @unique @map("onboarded_from_email_message_id")
  onboardedFromEmailMessage   EmailMessage? @relation("OnboardingSourceEmail", fields: [onboardedFromEmailMessageId], references: [id])

  // Phase Incidents — every NEW claim is now created from an Incident
  // (the "Upgrade to claim" action). Nullable on the column so existing
  // claims keep working unchanged; new claims always set it. The
  // carrier-required floor that used to live on the auto-draft path
  // moves to the upgrade form gated on this FK.
  incidentId String?    @map("incident_id")
  incident   Incident?  @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  submittedAt DateTime? @map("submitted_at")
  settledAt   DateTime? @map("settled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  booking            Booking?            @relation(fields: [bookingId], references: [id])
  asset              Asset?              @relation(fields: [assetId], references: [id])
  company            Company             @relation(fields: [companyId], references: [id])
  checkoutInspection Inspection?         @relation("CheckoutInspection", fields: [checkoutInspectionId], references: [id])
  returnInspection   Inspection?         @relation("ReturnInspection", fields: [returnInspectionId], references: [id])
  invoice            Invoice?            @relation(fields: [invoiceId], references: [id])
  coiCheck           CoiCheck?           @relation(fields: [coiCheckId], references: [id])
  assignedToUser     User?               @relation("ClaimAssignee", fields: [assignedTo], references: [id])
  documents          ClaimDocument[]
  timeline           ClaimTimeline[]
  damageItems        DamageItem[]
  maintenanceRecords MaintenanceRecord[]
  // Reverse relations for the claims@ → onboarding bridge. sourceEmails
  // is every EmailMessage attached to this claim (correspondence inbox);
  // onboardingSource is exactly the message that drafted this claim (for
  // FROM_EMAIL_REVIEW badge + click-through).
  sourceEmails       EmailMessage[]      @relation("ClaimSourceEmails")
  // Reverse for ClaimMail.claim — every triage row that ended up
  // attached to this claim. Many-to-one because one claim can collect
  // multiple inbound emails over its life (initial draft + follow-up
  // attaches).
  claimMail          ClaimMail[]

  @@index([invoiceId])
  @@index([coiCheckId])
  @@map("insurance_claims")
}

enum ClaimDocType {
  CHECKOUT_PHOTO
  RETURN_PHOTO
  REPAIR_ESTIMATE
  REPAIR_INVOICE
  DEMAND_LETTER
  COUNTER_LETTER
  COI
  RENTAL_AGREEMENT
  CORRESPONDENCE
  SETTLEMENT
  // Added with the typed-document system (drag-drop upload +
  // AI classification + email-attachment reclassification). Coexists
  // with the existing CHECKOUT_PHOTO/RETURN_PHOTO values — both stay
  // for legacy rows; the classifier's UI prompt only suggests from
  // the simpler new-vocabulary set.
  PHOTO
  DAMAGE_INVOICE
  POLICE_REPORT
  OTHER
}

// How a ClaimDocument's `type` was decided. Drives the UI cue:
// AI_SUGGESTED renders with a "review" affordance until the user
// confirms; the moment they touch the type chip we flip it to USER.
// EMAIL_INGEST is the pre-classifier legacy default for attachments
// the email pipeline used to flatten to CORRESPONDENCE — kept so
// migration of older rows can tell user-confirmed types apart from
// the inferred ones.
enum DocTypeSource {
  EMAIL_INGEST
  USER
  AI_SUGGESTED
}

model ClaimDocument {
  id         String       @id @default(uuid())
  // Phase Incidents — claimId becomes nullable so the document can
  // attach to either a Claim OR an Incident (incidentId below). Legacy
  // rows always have claimId set; new writes pick exactly one. The
  // "exactly one" invariant is app-layer (no partial CHECK constraint
  // in Postgres without an extension); the upload routes enforce it.
  claimId    String?      @map("claim_id")
  incidentId String?      @map("incident_id")
  type       ClaimDocType
  // Provenance of the `type` decision. NULL on rows written before
  // the typed-document system shipped — UI treats null as "unknown
  // source, treat as user-set" so legacy rows don't surface a phantom
  // review prompt. New writes always populate this.
  typeSource DocTypeSource? @map("type_source")
  // AI confidence score when typeSource = AI_SUGGESTED. 0..1 scale,
  // matching the messageExtractor + reply-classifier convention.
  // NULL for USER / EMAIL_INGEST sources where confidence is N/A.
  typeConfidence Float?  @map("type_confidence")
  title      String
  fileUrl    String       @map("file_url")
  uploadedBy String?      @map("uploaded_by")
  notes      String?      @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  claim          InsuranceClaim? @relation(fields: [claimId], references: [id], onDelete: Cascade)
  incident       Incident?       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploadedByUser User?           @relation("DocUploader", fields: [uploadedBy], references: [id])

  @@index([claimId])
  @@index([incidentId])
  @@map("claim_documents")
}

enum ClaimAction {
  CREATED
  SUBMITTED
  ADJUSTER_ASSIGNED
  OFFER_RECEIVED
  COUNTER_SENT
  NEGOTIATION_NOTE
  SETTLED
  DENIED
  ESCALATED
  DOCUMENT_ADDED
}

model ClaimTimeline {
  id          String      @id @default(uuid())
  claimId     String      @map("claim_id")
  action      ClaimAction
  description String      @db.Text
  amount      Decimal?    @db.Decimal(10, 2)
  performedBy String?     @map("performed_by")
  isAi        Boolean     @default(false) @map("is_ai_generated")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  claim           InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  performedByUser User?          @relation("TimelineActor", fields: [performedBy], references: [id])

  @@map("claim_timeline")
}

// ═══════════════════════════════════════
// 10. AI BOOKING AGENT
// ═══════════════════════════════════════

enum AiDecisionType {
  AUTO_APPROVE
  APPROVE_WITH_SUBS
  NEEDS_REVIEW
  WAITLIST
  DENY
}

model AiDecision {
  id                   String         @id @default(uuid())
  bookingId            String         @map("booking_id")
  decision             AiDecisionType
  confidence           Int // 0-100
  summary              String         @db.Text
  suggestedAssignments Json?          @map("suggested_assignments")
  alternativesOffered  Json?          @map("alternatives_offered")
  conflictsDetected    Json?          @map("conflicts_detected")
  revenueEstimate      Decimal?       @map("revenue_estimate") @db.Decimal(12, 2)
  upsellSuggestions    Json?          @map("upsell_suggestions")
  draftClientMessage   String?        @map("draft_client_message") @db.Text
  wasOverridden        Boolean        @default(false) @map("was_overridden")
  overrideReason       String?        @map("override_reason") @db.Text
  overriddenBy         String?        @map("overridden_by")
  processingTimeMs     Int?           @map("processing_time_ms")
  modelVersion         String?        @map("model_version")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  booking        Booking @relation(fields: [bookingId], references: [id])
  overriddenUser User?   @relation("AiOverrider", fields: [overriddenBy], references: [id])

  @@map("ai_decisions")
}

// ═══════════════════════════════════════
// 11. GMAIL INTEGRATION
// ═══════════════════════════════════════

model EmailAccount {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  emailAddress String    @unique @map("email_address") // jose@sirreel.com
  accessToken  String?   @map("access_token") @db.Text
  refreshToken String?   @map("refresh_token") @db.Text
  tokenExpiry  DateTime? @map("token_expiry")
  lastSyncAt   DateTime? @map("last_sync_at")
  // Ground truth for the last SUCCESSFUL Gmail watch renewal. Stamped
  // inside /api/gmail/watch on the per-inbox `gmail.users.watch()`
  // success path. The dead-man's-switch health probe alerts when this
  // goes stale past the 7-day Gmail watch TTL on any active inbox.
  lastWatchedAt DateTime? @map("last_watched_at")
  isActive     Boolean   @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user     User           @relation(fields: [userId], references: [id])
  messages EmailMessage[]

  @@map("email_accounts")
}

model EmailThread {
  id            String   @id @default(uuid())
  gmailThreadId String   @unique @map("gmail_thread_id")
  subject       String
  lastMessageAt DateTime @map("last_message_at")
  messageCount  Int      @default(0) @map("message_count")

  aiSummary   String?   @map("ai_summary") @db.Text
  aiSummaryAt DateTime? @map("ai_summary_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Direction tracking (May 2026). Maintained by the Pub/Sub handler on
  // every new message and by the one-time backfill seed for historical
  // threads. Drives the suggested-inquiries filter — a thread whose most
  // recent message is OUTBOUND drops off the Inquiries list.
  lastInboundAt  DateTime? @map("last_inbound_at")
  lastOutboundAt DateTime? @map("last_outbound_at")
  lastDirection  String?   @map("last_direction")

  // Relations
  messages EmailMessage[]

  @@index([lastDirection, lastInboundAt])
  @@map("email_threads")
}

model EmailMessage {
  id             String  @id @default(uuid())
  emailAccountId String  @map("email_account_id")
  threadId       String? @map("thread_id")
  gmailMessageId String  @unique @map("gmail_message_id")

  // RFC 822 Message-ID + In-Reply-To headers. Unlike gmailMessageId (which is
  // per-inbox), the RFC 822 Message-ID is set by the sending mail server and
  // is the same across every inbox that receives the message — so it's the
  // key we dedup on when info@/jose@/oliver@/ana@ all get the same email.
  // `inReplyTo` drives "first message in thread" detection on the Inquiries
  // panel (a message with no In-Reply-To is a fresh thread start).
  rfc822MessageId String? @map("rfc822_message_id")
  inReplyTo       String? @map("in_reply_to")

  // Cross-inbox dedup: when two EmailMessages share the same Message-ID, the
  // oldest createdAt wins and the rest point here. `duplicateOfId IS NULL`
  // is the canonical "this is the surviving copy" filter for queries.
  duplicateOfId String?       @map("duplicate_of_id")
  duplicateOf   EmailMessage? @relation("EmailDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates    EmailMessage[] @relation("EmailDuplicates")

  // CRH reply classification — output of the AI reply classifier (extends
  // the existing inbound-email classifier). Drives cadence state transitions
  // when a client replies to a quote. Confidence < 0.75 must NEVER trigger
  // an auto-transition; the cadence runner pauses and notifies the rep.
  replyClassification           ReplyClassification? @map("reply_classification")
  replyClassificationConfidence Float?               @map("reply_classification_confidence")

  // Per-message AI extraction — structured fields (contact, company,
  // jobIntent, urgency, summary) parsed out of the email body so the
  // Pipeline slider can render a Quick Read card instead of raw text. See
  // src/lib/ai/messageExtractor.ts for the JSON shape and prompt.
  // Cached per-message; backfill script populates historical rows.
  extractedData         Json?     @map("extracted_data")
  extractionRunAt       DateTime? @map("extraction_run_at")
  extractionConfidence  Float?    @map("extraction_confidence")

  // Heuristic form-type detection from the Subject line. Cognito Forms
  // submissions land with predictable prefixes ("NEW INQUIRY",
  // "Annual Rental Agreement", etc.); this regex-based classification
  // gives the pipeline slider a colored badge per type so the team can
  // see at a glance what each item is. Routing isn't affected yet.
  // See src/lib/email/inferFormType.ts.
  inferredFormType InferredFormType? @map("inferred_form_type")

  // Matched to CRM
  companyId String? @map("company_id")
  personId  String? @map("person_id")

  // Matched to an InsuranceClaim by the claims@ → onboarding handler
  // (src/lib/claims/onboardFromEmail.ts). Set whenever the helper
  // attaches the message to an existing claim OR auto-creates a DRAFT
  // from it. Cross-inbox idempotency contract: before the helper acts,
  // it looks up any EmailMessage sharing this row's rfc822MessageId where
  // claimId IS NOT NULL — if found, skip. So a claims@ + ana@ duplicate
  // pair can never trigger double-onboarding regardless of which row is
  // canonical.
  claimId String? @map("claim_id")

  fromAddress String   @map("from_address")
  toAddresses String[] @map("to_addresses")
  subject     String
  snippet     String?  @db.Text // Preview text from Gmail
  direction   String // "inbound" or "outbound"

  // Full message body (populated by Pub/Sub handler with format: "full" and
  // the May 2026 backfill). bodyText is preferred; bodyHtml is kept for
  // display fidelity; bodySource records which path produced bodyText
  // ('plain' = text/plain part directly, 'html-converted' = html-to-text).
  bodyText        String? @map("body_text") @db.Text
  bodyHtml        String? @map("body_html") @db.Text
  bodySource      String? @map("body_source")
  attachmentCount Int     @default(0) @map("attachment_count")

  // Routing headers captured from the Gmail payload at ingest time, so
  // forwarded mail (e.g. claims@ → ana@) can be classified by its ORIGINAL
  // recipient instead of just the inbox it landed in. Stored as JSON to
  // stay schema-light while keeping the keys queryable via Prisma's Json
  // path filters. Shape:
  //   { to, cc, deliveredTo, xOriginalTo, xForwardedFor, xForwardedTo }
  // All values are lower-cased on write so equality / contains filters
  // don't need to worry about case sensitivity.
  routingHeaders Json? @map("routing_headers")

  sentAt       DateTime       @map("sent_at")
  isRead       Boolean        @default(false) @map("is_read")
  // Triage
  category     EmailCategory? @map("category")
  status       EmailStatus    @default(UNREAD) @map("status")
  priority     Int            @default(5) @map("priority")
  assignedToId String?        @map("assigned_to_id")
  triageNotes  String?        @map("triage_notes") @db.Text
  triageAt     DateTime?      @map("triage_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id])
  thread       EmailThread? @relation(fields: [threadId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  person       Person?      @relation(fields: [personId], references: [id])
  claim        InsuranceClaim? @relation("ClaimSourceEmails", fields: [claimId], references: [id])
  // Inverse of InsuranceClaim.onboardedFromEmailMessage — present on
  // exactly one EmailMessage per auto-drafted claim. Used by the claim
  // detail page to render the source-chain link back to this row.
  draftedClaim InsuranceClaim? @relation("OnboardingSourceEmail")
  // ClaimMail triage row — one per claims@-inbox EmailMessage. Drives
  // the triage widget on /claims.
  claimMail    ClaimMail?

  @@index([rfc822MessageId])
  @@index([duplicateOfId])
  @@index([claimId])
  @@map("email_messages")
}

// Per-inbox kept-vs-dropped counter for the ingest filter. Lets us
// tune the SALES negative junk-filter without flying blind: see which
// reason is firing most, whether a real human lead is being dropped,
// etc. Single row per inbox; updated in the pubsub handler at filter
// time. The dropped count is not a recoverable archive — dropped mail
// stays in Gmail itself, which remains the authoritative store of
// record for anything we deliberately didn't pull into the DB.
// Per-message disposition for inbound claims@ mail. Replaces the
// silent-skip behavior of onboardFromEmail — every claims@ email gets
// exactly one ClaimMail row written, so the triage widget can show
// what happened (drafted? attached? still needs review? ignored?).
//
// Disposition rules (recorded by onboardFromEmail):
//   DRAFTED       — carrier identified + matched company → auto-drafted
//                   a new claim. claimId set.
//   ATTACHED      — parsed.carrierClaimNumber matched an existing
//                   claim. claimId set.
//   NEEDS_REVIEW  — lossDescription and/or client identified but no
//                   carrier (so DRAFTED's carrier-required floor
//                   couldn't fire). Parse is preserved so the Create-
//                   claim modal can pre-fill from it.
//   IGNORED       — no loss/incident described. Still shown in the
//                   widget (muted) so the rep can manually onboard
//                   if the classifier got it wrong.
//
// The unique constraint on emailMessageId makes the upsert idempotent
// across retries (helper crashed midway, cron re-ran it, etc.).
enum ClaimMailDisposition {
  DRAFTED
  ATTACHED
  NEEDS_REVIEW
  IGNORED
}

model ClaimMail {
  id             String               @id @default(uuid())
  emailMessageId String               @unique @map("email_message_id")
  inbox          String
  disposition    ClaimMailDisposition
  // The Sonnet parse output (ParsedClaim shape) — preserved so the
  // Create-claim modal can pre-fill on NEEDS_REVIEW without paying
  // for a second Sonnet call. Null when the parse never ran (rare —
  // body-too-short skip; the row still exists with disposition
  // IGNORED so the message isn't invisible).
  parse          Json?
  // Set for DRAFTED + ATTACHED. The matching InsuranceClaim row.
  claimId        String?              @map("claim_id")
  // Phase Incidents — set when a NEEDS_REVIEW row is upgraded via
  // "Open incident report" or when an auto-DRAFTED claim's incident
  // parent is created. Forward-only on the column; existing rows stay
  // null and the triage UI treats null as "no incident yet, action
  // creates one".
  incidentId     String?              @map("incident_id")
  // Free-form one-liner — why this disposition. e.g. "no matching
  // Company in CRM" on NEEDS_REVIEW, "body too short" on IGNORED.
  reason         String?

  // Reviewer state — Dismiss / Create-claim buttons in the widget
  // stamp these so the row drops out of the active triage view.
  dismissed      Boolean              @default(false)
  reviewedById   String?              @map("reviewed_by_id")
  reviewedAt     DateTime?            @map("reviewed_at")

  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  emailMessage EmailMessage    @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  claim        InsuranceClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  incident     Incident?       @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  reviewedBy   User?           @relation("ClaimMailReviewer", fields: [reviewedById], references: [id])

  @@index([disposition, dismissed])
  @@index([createdAt])
  @@index([incidentId])
  @@map("claim_mail")
}

model IngestFilterStat {
  inbox          String    @id
  mode           String    // 'SALES' | 'MONEY' | 'CLAIMS' | 'PRESERVE'
  kept           Int       @default(0)
  dropped        Int       @default(0)
  lastDropReason String?   @map("last_drop_reason")
  lastDropAt     DateTime? @map("last_drop_at")
  lastKeptAt     DateTime? @map("last_kept_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("ingest_filter_stats")
}

