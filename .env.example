# ═══════════════════════════════════════
# SIRREEL PLATFORM — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════

# Database (Vercel Postgres, Supabase, Neon, or any PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/sirreel?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google Workspace OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic (AI Assistant + Booking Agent + Claims)
ANTHROPIC_API_KEY=""

# RentalWorks API (Phase 2)
RENTALWORKS_URL="https://yourcompany.rentalworksweb.com"
RENTALWORKS_API_KEY=""

# SendGrid (Mass Email — Phase 2)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="bookings@sirreel.com"

# File Storage (Cloudflare R2 or AWS S3)
S3_ENDPOINT=""
S3_BUCKET="sirreel-files"
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Slack (alerts from /api/cron/health-check)
SLACK_BOT_TOKEN=""
SLACK_ALERT_CHANNEL="#sirreel-alerts"

# Cron auth shared secret (Vercel Cron sends this in the Authorization header)
CRON_SECRET=""

# Google Pub/Sub push OIDC verification (/api/gmail/pubsub).
# Set BOTH the subscription's push auth (service account + audience) in GCP
# and these two vars to activate enforcement; while unset the endpoint
# logs a warning and allows (so ingestion doesn't go dark pre-config).
PUBSUB_PUSH_SERVICE_ACCOUNT=""
PUBSUB_PUSH_AUDIENCE=""

# CardPointe (CardConnect) — card + ACH processing.
# CARDPOINTE_ENV selects which credential set is used: "UAT" (default,
# sandbox) or "PROD". The tokenizer iframe AND the REST gateway both
# resolve their host from the active env's *_URL, so a token is always
# minted on the same environment it is charged against.
# The *_URL is the BARE host WITH scheme and NO path
# (e.g. https://fts-uat.cardconnect.com or https://fts.cardconnect.com) —
# the client appends /itoke/ (tokenizer) and /cardconnect/rest (gateway).
CARDPOINTE_ENV="UAT"
CARDPOINTE_UAT_URL="https://fts-uat.cardconnect.com"
CARDPOINTE_UAT_MID=""
CARDPOINTE_UAT_USERNAME=""
CARDPOINTE_UAT_PASSWORD=""
# Production set — required only when CARDPOINTE_ENV=PROD.
CARDPOINTE_PROD_URL="https://fts.cardconnect.com"
CARDPOINTE_PROD_MID=""
CARDPOINTE_PROD_USERNAME=""
CARDPOINTE_PROD_PASSWORD=""
# ACH (eCheck) is gated OFF until CardConnect eCheck underwriting is live
# AND achStatusMapping is verified. Set BOTH to "true" to enable; the
# NEXT_PUBLIC_ one exposes the pay-by-bank option in the portal UI.
ACH_ENABLED=""
NEXT_PUBLIC_ACH_ENABLED=""

# Fleet-readiness reminder kill switch. The daily cron
# (/api/cron/fleet-readiness) only SENDS its Slack/email digest when this
# is exactly "true"; any other value (or unset) runs the full selection
# logic but logs the would-be payloads ([fleet-readiness DRY-RUN]) and
# sends nothing. Intentionally left unset everywhere until Wes flips it
# on in Vercel.
FLEET_REMINDERS_ENABLED=""
